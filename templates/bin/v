#!/bin/sh

set -eu

CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}"
KIT_DIR="$CONFIG_DIR/vibe-cli-kit"
TEMPLATE_DIR="$KIT_DIR/templates"
CHEATSHEET_DIR="$CONFIG_DIR/cheatsheets"
LOCAL_BIN_DIR="$HOME/.local/bin"
SHELL_RC="$HOME/.zshrc"
SESSION_CONFIG_FILE="$KIT_DIR/session.conf"
START_MARKER="# >>> vibe-cli-kit >>>"
END_MARKER="# <<< vibe-cli-kit <<<"
SYNC_TARGET=all
SYNC_MODE=overwrite
SYNC_DRY_RUN=0
DIFF_TARGET=all
UPDATE_DRY_RUN=0
UPDATE_SYNC=1
BACKUP_TARGET=all
SESSION_RESET=0

UPDATED_COUNT=0
UPDATED_ITEMS=
SKIPPED_ITEMS=
FAILED_ITEMS=

OK_COUNT=0
WARN_COUNT=0
FAIL_COUNT=0
SESSION_CONFIG_LOADED=0

usage() {
  cat <<'EOF'
Usage:
  v
  v [--lang en|zh-CN|ja]
  v doctor
  v backup [--only all|ghostty|yazi|tmux|cheatsheets|bin|session|shell]
  v diff [--only all|ghostty|yazi|tmux|cheatsheets|bin|session|shell]
  v sync [--dry-run] [--only all|ghostty|yazi|tmux|cheatsheets|bin|session|shell] [--mode overwrite|skip|backup]
  v update [--dry-run] [--no-sync]
  v session [code|backend|frontend|ai] [--name SESSION] [--reset]
  v project
  v r --port PORT [--wait SECONDS] [--] [COMMAND...]
  v --help
EOF
}

open_cheatsheet() {
  if command -v terminal-cheatsheet >/dev/null 2>&1; then
    exec terminal-cheatsheet "$@"
  fi

  if [ -x "$LOCAL_BIN_DIR/terminal-cheatsheet" ]; then
    exec "$LOCAL_BIN_DIR/terminal-cheatsheet" "$@"
  fi

  printf 'terminal-cheatsheet not found\n' >&2
  exit 1
}

session_help() {
  cat <<'EOF'
Usage:
  v session [code|backend|frontend|ai] [--name SESSION] [--reset]

Layouts:
  code
  +---------------------------+-------------+
  | yazi                      | shell       |
  |                           +-------------+
  |                           | git         |
  +---------------------------+-------------+

  backend
  +---------------------------+-------------+
  | server                    | tests       |
  |                           +-------------+
  |                           | git         |
  +---------------------------+-------------+

  frontend
  +---------------------------+-------------+
  | yazi                      | dev         |
  |                           +-------------+
  |                           | git         |
  +---------------------------+-------------+

  ai
  +---------------------------+-------------+
  | yazi                      | git         |
  +---------------------------+-------------+
  | ai                        | shell       |
  +---------------------------+-------------+

Naming:
  code      -> current-directory
  others    -> current-directory-layout
  override  -> --name SESSION

Behavior:
  existing session -> reuse by default
  --reset          -> recreate the target session from scratch
  config file      -> ~/.config/vibe-cli-kit/session.conf

Examples:
  v session code
  v session backend
  v session frontend
  v session ai
  v session ai --name vibe-ai
  v session ai --name vibe-ai --reset
EOF
}

project_help() {
  cat <<'EOF'
Usage:
  v project

Output:
  - detected project type
  - preferred package runner
  - suggested dev / test commands
EOF
}

restart_help() {
  cat <<'EOF'
Usage:
  v r PORT [COMMAND...]
  v r --port PORT [--wait SECONDS] [--] [COMMAND...]

Behavior:
  - finds processes listening on PORT and stops them before starting the next command
  - when COMMAND is omitted, uses the current project's suggested dev command
  - when auto-detection cannot find a startup command, prints actionable hints
  - accepts PORT as a positional argument, via --port, or from the current shell environment

Examples:
  v r 3000
  v r 3000 pnpm dev
  PORT=8000 v r -- uv run uvicorn app.main:app --reload
  v r --port 5173
EOF
}

diff_help() {
  cat <<'EOF'
Usage:
  v diff [--only all|ghostty|yazi|tmux|cheatsheets|bin|session|shell]

Behavior:
  - compares the local template store with deployed files
  - shell mode compares only the managed vibe-cli-kit block in ~/.zshrc
  - exits 0 when no differences are found
EOF
}

backup_help() {
  cat <<'EOF'
Usage:
  v backup [--only all|ghostty|yazi|tmux|cheatsheets|bin|session|shell]

Behavior:
  - backs up deployed files into ~/.config/vibe-cli-kit/backups/<timestamp>/
  - shell mode backs up only the managed vibe-cli-kit block from ~/.zshrc
  - never overwrites an existing backup directory
EOF
}

report_ok() {
  OK_COUNT=$((OK_COUNT + 1))
  printf 'ok    %s\n' "$*"
}

report_warn() {
  WARN_COUNT=$((WARN_COUNT + 1))
  printf 'warn  %s\n' "$*"
}

report_fail() {
  FAIL_COUNT=$((FAIL_COUNT + 1))
  printf 'fail  %s\n' "$*"
}

report_skip() {
  printf 'skip  %s\n' "$*"
}

append_line() {
  list_name="$1"
  item="$2"
  eval "current_value=\${$list_name:-}"
  if [ -z "$current_value" ]; then
    eval "$list_name=\"\$item\""
  else
    eval "$list_name=\"\$current_value
\$item\""
  fi
}

check_file() {
  label="$1"
  path="$2"
  if [ -f "$path" ]; then
    report_ok "$label: $path"
  else
    report_fail "$label: missing ($path)"
  fi
}

copy_file() {
  src="$1"
  dest="$2"

  if [ ! -f "$src" ]; then
    printf 'fail  missing template: %s\n' "$src" >&2
    exit 1
  fi

  mkdir -p "$(dirname "$dest")"

  if [ -f "$dest" ]; then
    case "$SYNC_MODE" in
      skip)
        printf 'skip  %s\n' "$dest"
        return 0
        ;;
      backup)
        backup_path="$dest.bak.$(date +%Y%m%d-%H%M%S)"
        if [ "$SYNC_DRY_RUN" -eq 1 ]; then
          printf 'dry   cp %s %s\n' "$dest" "$backup_path"
        else
          cp "$dest" "$backup_path"
        fi
        ;;
    esac
  fi

  if [ "$SYNC_DRY_RUN" -eq 1 ]; then
    printf 'dry   cp %s %s\n' "$src" "$dest"
  else
    cp "$src" "$dest"
    printf 'sync  %s\n' "$dest"
  fi
}

check_cmd() {
  label="$1"
  primary="$2"
  fallback="${3:-}"

  if command -v "$primary" >/dev/null 2>&1; then
    report_ok "$label: $(command -v "$primary")"
    return 0
  fi

  if [ -n "$fallback" ] && command -v "$fallback" >/dev/null 2>&1; then
    report_ok "$label: $(command -v "$fallback") (via $fallback)"
    return 0
  fi

  report_warn "$label: command not found"
}

check_zshrc_markers() {
  if [ ! -f "$SHELL_RC" ]; then
    report_fail "shell integration: missing $SHELL_RC"
    return 0
  fi

  if grep -Fq "$START_MARKER" "$SHELL_RC" && grep -Fq "$END_MARKER" "$SHELL_RC"; then
    report_ok "shell integration: managed block found in $SHELL_RC"
  else
    report_fail "shell integration: managed block missing in $SHELL_RC"
  fi
}

check_ghostty() {
  if [ "$(uname -s)" = "Darwin" ]; then
    if [ -d "/Applications/Ghostty.app" ] || command -v ghostty >/dev/null 2>&1; then
      if command -v ghostty >/dev/null 2>&1; then
        report_ok "ghostty: $(command -v ghostty)"
      else
        report_ok "ghostty: /Applications/Ghostty.app"
      fi
    else
      report_warn "ghostty: not found on macOS"
    fi
  else
    report_skip "ghostty: auto-install is macOS-only"
  fi
}

check_yazi_plugin() {
  plugin_dir="$CONFIG_DIR/yazi/plugins/piper.yazi"
  if [ -d "$plugin_dir" ]; then
    report_ok "yazi plugin: $plugin_dir"
  else
    report_warn "yazi plugin: missing ($plugin_dir)"
  fi
}

check_template_store() {
  if [ -d "$TEMPLATE_DIR" ]; then
    report_ok "template store: $TEMPLATE_DIR"
  else
    report_fail "template store: missing ($TEMPLATE_DIR)"
  fi
}

append_managed_block() {
  snippet="$1"
  tmp_file="$SHELL_RC.vibe-cli-kit.tmp"

  mkdir -p "$(dirname "$SHELL_RC")"
  [ -f "$SHELL_RC" ] || : > "$SHELL_RC"

  if [ "$SYNC_DRY_RUN" -eq 1 ]; then
    printf 'dry   update managed block in %s\n' "$SHELL_RC"
    return 0
  fi

  awk -v start="$START_MARKER" -v end="$END_MARKER" '
    $0 == start { skip=1; next }
    $0 == end { skip=0; next }
    skip != 1 { print }
  ' "$SHELL_RC" > "$tmp_file"

  {
    cat "$tmp_file"
    printf '\n%s\n' "$START_MARKER"
    cat "$snippet"
    printf '%s\n' "$END_MARKER"
  } > "$SHELL_RC"

  rm -f "$tmp_file"
  printf 'sync  %s\n' "$SHELL_RC"
}

sync_ghostty() {
  copy_file "$TEMPLATE_DIR/ghostty/config" "$CONFIG_DIR/ghostty/config"
}

sync_yazi() {
  copy_file "$TEMPLATE_DIR/yazi/yazi.toml" "$CONFIG_DIR/yazi/yazi.toml"
  copy_file "$TEMPLATE_DIR/yazi/package.toml" "$CONFIG_DIR/yazi/package.toml"
}

sync_tmux() {
  copy_file "$TEMPLATE_DIR/tmux/tmux.conf" "$HOME/.tmux.conf"
}

copy_file_if_missing() {
  src="$1"
  dest="$2"

  if [ -f "$dest" ]; then
    printf 'skip  %s\n' "$dest"
    return 0
  fi

  copy_file "$src" "$dest"
}

sync_session() {
  copy_file_if_missing "$TEMPLATE_DIR/session/session.conf.example" "$KIT_DIR/session.conf"
  copy_file "$TEMPLATE_DIR/session/session.conf.example" "$KIT_DIR/session.conf.example"
}

sync_cheatsheets() {
  copy_file "$TEMPLATE_DIR/cheatsheets/terminal-cheatsheet.en.md" "$CHEATSHEET_DIR/terminal-cheatsheet.en.md"
  copy_file "$TEMPLATE_DIR/cheatsheets/terminal-cheatsheet.zh-CN.md" "$CHEATSHEET_DIR/terminal-cheatsheet.zh-CN.md"
  copy_file "$TEMPLATE_DIR/cheatsheets/terminal-cheatsheet.ja.md" "$CHEATSHEET_DIR/terminal-cheatsheet.ja.md"
}

sync_bin() {
  copy_file "$TEMPLATE_DIR/bin/terminal-cheatsheet" "$LOCAL_BIN_DIR/terminal-cheatsheet"
  copy_file "$TEMPLATE_DIR/bin/tmx" "$LOCAL_BIN_DIR/tmx"
  copy_file "$TEMPLATE_DIR/bin/v" "$LOCAL_BIN_DIR/v"
  copy_file "$TEMPLATE_DIR/bin/e" "$LOCAL_BIN_DIR/e"
  copy_file "$TEMPLATE_DIR/bin/fif" "$LOCAL_BIN_DIR/fif"
  if [ "$SYNC_DRY_RUN" -eq 1 ]; then
    printf 'dry   chmod +x %s %s %s %s %s\n' "$LOCAL_BIN_DIR/terminal-cheatsheet" "$LOCAL_BIN_DIR/tmx" "$LOCAL_BIN_DIR/v" "$LOCAL_BIN_DIR/e" "$LOCAL_BIN_DIR/fif"
  else
    chmod +x "$LOCAL_BIN_DIR/terminal-cheatsheet" "$LOCAL_BIN_DIR/tmx" "$LOCAL_BIN_DIR/v" "$LOCAL_BIN_DIR/e" "$LOCAL_BIN_DIR/fif"
    printf 'sync  chmod +x scripts in %s\n' "$LOCAL_BIN_DIR"
  fi
}

sync_shell() {
  snippet="$TEMPLATE_DIR/shell/zshrc.snippet"
  if [ ! -f "$snippet" ]; then
    printf 'fail  missing template: %s\n' "$snippet" >&2
    exit 1
  fi
  append_managed_block "$snippet"
}

sync_target() {
  case "$1" in
    all)
      sync_ghostty
      sync_yazi
      sync_tmux
      sync_session
      sync_cheatsheets
      sync_bin
      sync_shell
      ;;
    ghostty) sync_ghostty ;;
    yazi) sync_yazi ;;
    tmux) sync_tmux ;;
    session) sync_session ;;
    cheatsheets) sync_cheatsheets ;;
    bin) sync_bin ;;
    shell) sync_shell ;;
    *)
      usage >&2
      exit 1
      ;;
  esac
}

parse_sync_args() {
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --dry-run)
        SYNC_DRY_RUN=1
        ;;
      --only)
        shift
        [ "$#" -gt 0 ] || {
          usage >&2
          exit 1
        }
        SYNC_TARGET="$1"
        ;;
      --mode)
        shift
        [ "$#" -gt 0 ] || {
          usage >&2
          exit 1
        }
        SYNC_MODE="$1"
        ;;
      *)
        usage >&2
        exit 1
        ;;
    esac
    shift
  done

  case "$SYNC_MODE" in
    overwrite|skip|backup) ;;
    *)
      usage >&2
      exit 1
      ;;
  esac
}

sync_configs() {
  parse_sync_args "$@"

  if [ ! -d "$TEMPLATE_DIR" ]; then
    printf 'fail  template store missing: %s\n' "$TEMPLATE_DIR" >&2
    printf 'hint  re-run: sh install.sh --only-config\n' >&2
    exit 1
  fi

  printf 'vibe-cli-kit sync\n'
  printf 'target=%s mode=%s dry-run=%s\n\n' "$SYNC_TARGET" "$SYNC_MODE" "$SYNC_DRY_RUN"
  sync_target "$SYNC_TARGET"
}

ensure_template_store() {
  if [ ! -d "$TEMPLATE_DIR" ]; then
    printf 'fail  template store missing: %s\n' "$TEMPLATE_DIR" >&2
    printf 'hint  re-run: sh install.sh --only-config\n' >&2
    exit 1
  fi
}

backup_root_dir() {
  base_dir="$KIT_DIR/backups"
  timestamp="$(date +%Y%m%d-%H%M%S)"
  suffix=0

  mkdir -p "$base_dir"

  while :; do
    if [ "$suffix" -eq 0 ]; then
      candidate="$base_dir/$timestamp"
    else
      candidate="$base_dir/$timestamp-$suffix"
    fi

    if mkdir "$candidate" 2>/dev/null; then
      printf '%s\n' "$candidate"
      return 0
    fi

    suffix=$((suffix + 1))
  done
}

backup_copy_file() {
  label="$1"
  src="$2"
  dest="$3"
  if [ ! -f "$src" ]; then
    printf 'skip  %s missing: %s\n' "$label" "$src"
    return 0
  fi
  mkdir -p "$(dirname "$dest")"
  cp "$src" "$dest"
  printf 'ok    backup %s -> %s\n' "$label" "$dest"
}

backup_target() {
  target="$1"
  root="$2"
  case "$target" in
    ghostty)
      backup_copy_file ghostty "$CONFIG_DIR/ghostty/config" "$root/ghostty/config"
      ;;
    yazi)
      backup_copy_file yazi.toml "$CONFIG_DIR/yazi/yazi.toml" "$root/yazi/yazi.toml"
      backup_copy_file yazi.package "$CONFIG_DIR/yazi/package.toml" "$root/yazi/package.toml"
      ;;
    tmux)
      backup_copy_file tmux "$HOME/.tmux.conf" "$root/tmux/tmux.conf"
      ;;
    session)
      backup_copy_file session "$KIT_DIR/session.conf" "$root/session/session.conf"
      backup_copy_file session.example "$KIT_DIR/session.conf.example" "$root/session/session.conf.example"
      ;;
    cheatsheets)
      backup_copy_file cheatsheet.en "$CHEATSHEET_DIR/terminal-cheatsheet.en.md" "$root/cheatsheets/terminal-cheatsheet.en.md"
      backup_copy_file cheatsheet.zh-CN "$CHEATSHEET_DIR/terminal-cheatsheet.zh-CN.md" "$root/cheatsheets/terminal-cheatsheet.zh-CN.md"
      backup_copy_file cheatsheet.ja "$CHEATSHEET_DIR/terminal-cheatsheet.ja.md" "$root/cheatsheets/terminal-cheatsheet.ja.md"
      ;;
    bin)
      backup_copy_file bin.terminal-cheatsheet "$LOCAL_BIN_DIR/terminal-cheatsheet" "$root/bin/terminal-cheatsheet"
      backup_copy_file bin.tmx "$LOCAL_BIN_DIR/tmx" "$root/bin/tmx"
      backup_copy_file bin.v "$LOCAL_BIN_DIR/v" "$root/bin/v"
      backup_copy_file bin.e "$LOCAL_BIN_DIR/e" "$root/bin/e"
      backup_copy_file bin.fif "$LOCAL_BIN_DIR/fif" "$root/bin/fif"
      ;;
    shell)
      tmp_file="$(mktemp)"
      extract_managed_block "$SHELL_RC" "$tmp_file"
      if [ -s "$tmp_file" ]; then
        mkdir -p "$root/shell"
        cp "$tmp_file" "$root/shell/zshrc.snippet"
        printf 'ok    backup shell.managed-block -> %s\n' "$root/shell/zshrc.snippet"
      else
        printf 'skip  shell.managed-block missing in %s\n' "$SHELL_RC"
      fi
      rm -f "$tmp_file"
      ;;
    all)
      backup_target ghostty "$root"
      backup_target yazi "$root"
      backup_target tmux "$root"
      backup_target session "$root"
      backup_target cheatsheets "$root"
      backup_target bin "$root"
      backup_target shell "$root"
      ;;
    *)
      backup_help >&2
      exit 1
      ;;
  esac
}

parse_backup_args() {
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --only)
        shift
        [ "$#" -gt 0 ] || {
          backup_help >&2
          exit 1
        }
        BACKUP_TARGET="$1"
        ;;
      -h|--help|help)
        backup_help
        exit 0
        ;;
      *)
        backup_help >&2
        exit 1
        ;;
    esac
    shift
  done
}

backup_configs() {
  parse_backup_args "$@"
  root="$(backup_root_dir)"
  printf 'vibe-cli-kit backup\n'
  printf 'target=%s\n' "$BACKUP_TARGET"
  printf 'dir=%s\n\n' "$root"
  backup_target "$BACKUP_TARGET" "$root"
}

extract_managed_block() {
  src_file="$1"
  out_file="$2"
  if [ ! -f "$src_file" ]; then
    : > "$out_file"
    return 0
  fi

  awk -v start="$START_MARKER" -v end="$END_MARKER" '
    $0 == start { capture=1; next }
    $0 == end { capture=0; exit }
    capture == 1 { print }
  ' "$src_file" > "$out_file"
}

run_diff_pair() {
  label="$1"
  left="$2"
  right="$3"
  if [ ! -f "$left" ] && [ ! -f "$right" ]; then
    printf 'skip  %s (both missing)\n' "$label"
    return 0
  fi
  if [ ! -f "$left" ]; then
    printf 'fail  %s missing template: %s\n' "$label" "$left" >&2
    return 1
  fi
  if [ ! -f "$right" ]; then
    printf 'warn  %s missing deployed file: %s\n' "$label" "$right"
    return 1
  fi
  if diff -u "$left" "$right"; then
    printf 'ok    %s\n' "$label"
    return 0
  fi
  printf 'warn  diff found: %s\n' "$label"
  return 1
}

diff_target() {
  target="$1"
  diff_found=0

  case "$target" in
    ghostty)
      run_diff_pair "ghostty" "$TEMPLATE_DIR/ghostty/config" "$CONFIG_DIR/ghostty/config" || diff_found=1
      ;;
    yazi)
      run_diff_pair "yazi.toml" "$TEMPLATE_DIR/yazi/yazi.toml" "$CONFIG_DIR/yazi/yazi.toml" || diff_found=1
      run_diff_pair "yazi.package" "$TEMPLATE_DIR/yazi/package.toml" "$CONFIG_DIR/yazi/package.toml" || diff_found=1
      ;;
    tmux)
      run_diff_pair "tmux" "$TEMPLATE_DIR/tmux/tmux.conf" "$HOME/.tmux.conf" || diff_found=1
      ;;
    session)
      run_diff_pair "session.conf" "$TEMPLATE_DIR/session/session.conf.example" "$KIT_DIR/session.conf" || diff_found=1
      run_diff_pair "session.conf.example" "$TEMPLATE_DIR/session/session.conf.example" "$KIT_DIR/session.conf.example" || diff_found=1
      ;;
    cheatsheets)
      run_diff_pair "cheatsheet.en" "$TEMPLATE_DIR/cheatsheets/terminal-cheatsheet.en.md" "$CHEATSHEET_DIR/terminal-cheatsheet.en.md" || diff_found=1
      run_diff_pair "cheatsheet.zh-CN" "$TEMPLATE_DIR/cheatsheets/terminal-cheatsheet.zh-CN.md" "$CHEATSHEET_DIR/terminal-cheatsheet.zh-CN.md" || diff_found=1
      run_diff_pair "cheatsheet.ja" "$TEMPLATE_DIR/cheatsheets/terminal-cheatsheet.ja.md" "$CHEATSHEET_DIR/terminal-cheatsheet.ja.md" || diff_found=1
      ;;
    bin)
      run_diff_pair "bin.terminal-cheatsheet" "$TEMPLATE_DIR/bin/terminal-cheatsheet" "$LOCAL_BIN_DIR/terminal-cheatsheet" || diff_found=1
      run_diff_pair "bin.tmx" "$TEMPLATE_DIR/bin/tmx" "$LOCAL_BIN_DIR/tmx" || diff_found=1
      run_diff_pair "bin.v" "$TEMPLATE_DIR/bin/v" "$LOCAL_BIN_DIR/v" || diff_found=1
      run_diff_pair "bin.e" "$TEMPLATE_DIR/bin/e" "$LOCAL_BIN_DIR/e" || diff_found=1
      run_diff_pair "bin.fif" "$TEMPLATE_DIR/bin/fif" "$LOCAL_BIN_DIR/fif" || diff_found=1
      ;;
    shell)
      tmp_left="$(mktemp)"
      tmp_right="$(mktemp)"
      cp "$TEMPLATE_DIR/shell/zshrc.snippet" "$tmp_left"
      extract_managed_block "$SHELL_RC" "$tmp_right"
      run_diff_pair "shell.managed-block" "$tmp_left" "$tmp_right" || diff_found=1
      rm -f "$tmp_left" "$tmp_right"
      ;;
    all)
      diff_target ghostty || diff_found=1
      diff_target yazi || diff_found=1
      diff_target tmux || diff_found=1
      diff_target session || diff_found=1
      diff_target cheatsheets || diff_found=1
      diff_target bin || diff_found=1
      diff_target shell || diff_found=1
      ;;
    *)
      usage >&2
      exit 1
      ;;
  esac

  return "$diff_found"
}

parse_diff_args() {
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --only)
        shift
        [ "$#" -gt 0 ] || {
          diff_help >&2
          exit 1
        }
        DIFF_TARGET="$1"
        ;;
      -h|--help|help)
        diff_help
        exit 0
        ;;
      *)
        diff_help >&2
        exit 1
        ;;
    esac
    shift
  done
}

diff_configs() {
  parse_diff_args "$@"
  ensure_template_store
  printf 'vibe-cli-kit diff\n'
  printf 'target=%s\n\n' "$DIFF_TARGET"
  diff_target "$DIFF_TARGET"
}

reset_update_state() {
  UPDATED_COUNT=0
  UPDATED_ITEMS=
  SKIPPED_ITEMS=
  FAILED_ITEMS=
}

detect_platform() {
  case "$(uname -s)" in
    Darwin) printf 'macos\n' ;;
    Linux)
      if grep -qiE 'microsoft|wsl' /proc/version 2>/dev/null; then
        printf 'wsl\n'
      else
        printf 'linux\n'
      fi
      ;;
    *)
      printf 'unknown\n'
      ;;
  esac
}

detect_package_manager() {
  platform="$(detect_platform)"
  case "$platform" in
    macos)
      if command -v brew >/dev/null 2>&1; then
        printf 'brew\n'
      elif command -v apt-get >/dev/null 2>&1; then
        printf 'apt\n'
      else
        printf 'unknown\n'
      fi
      ;;
    linux|wsl)
      if command -v apt-get >/dev/null 2>&1; then
        printf 'apt\n'
      elif command -v brew >/dev/null 2>&1; then
        printf 'brew\n'
      else
        printf 'unknown\n'
      fi
      ;;
    *)
      printf 'unknown\n'
      ;;
  esac
}

run_update_cmd() {
  if [ "$UPDATE_DRY_RUN" -eq 1 ]; then
    printf 'dry   %s\n' "$*"
    return 0
  fi
  "$@"
}

run_update_root_cmd() {
  if [ "$UPDATE_DRY_RUN" -eq 1 ]; then
    printf 'dry   %s\n' "$*"
    return 0
  fi

  if [ "$(id -u)" -eq 0 ]; then
    "$@"
  elif command -v sudo >/dev/null 2>&1; then
    sudo "$@"
  else
    printf 'fail  need root privileges: %s\n' "$*" >&2
    return 1
  fi
}

mark_updated() {
  UPDATED_COUNT=$((UPDATED_COUNT + 1))
  if [ "$UPDATE_DRY_RUN" -eq 1 ]; then
    append_line UPDATED_ITEMS "$1 (planned)"
    printf 'plan  update %s\n' "$1"
  else
    append_line UPDATED_ITEMS "$1"
    printf 'ok    updated %s\n' "$1"
  fi
}

mark_skipped() {
  append_line SKIPPED_ITEMS "$1"
  printf 'skip  %s\n' "$1"
}

mark_failed() {
  append_line FAILED_ITEMS "$1"
  printf 'warn  failed %s\n' "$1"
}

print_update_block() {
  title="$1"
  values="$2"
  [ -n "$values" ] || return 0
  printf '\n%s:\n' "$title"
  OLD_IFS=$IFS
  IFS='
'
  for item in $values; do
    [ -n "$item" ] && printf '  - %s\n' "$item"
  done
  IFS=$OLD_IFS
}

brew_update_formula() {
  formula="$1"
  if ! brew list --formula "$formula" >/dev/null 2>&1; then
    mark_skipped "$formula"
    return 0
  fi
  if run_update_cmd brew upgrade "$formula"; then
    mark_updated "$formula"
  else
    mark_failed "$formula"
  fi
}

brew_update_cask() {
  cask="$1"
  if brew list --cask "$cask" >/dev/null 2>&1 || [ -d "/Applications/Ghostty.app" ]; then
    if run_update_cmd brew upgrade --cask "$cask"; then
      mark_updated "$cask"
    else
      mark_failed "$cask"
    fi
  else
    mark_skipped "$cask"
  fi
}

apt_update_package() {
  pkg="$1"
  if ! dpkg -s "$pkg" >/dev/null 2>&1; then
    mark_skipped "$pkg"
    return 0
  fi
  if run_update_root_cmd apt-get install --only-upgrade -y "$pkg"; then
    mark_updated "$pkg"
  else
    mark_failed "$pkg"
  fi
}

update_python_cli() {
  package="$1"
  if command -v pipx >/dev/null 2>&1 && pipx list 2>/dev/null | grep -q "$package"; then
    if run_update_cmd pipx upgrade "$package"; then
      mark_updated "$package"
    else
      mark_failed "$package"
    fi
    return 0
  fi

  if command -v python3 >/dev/null 2>&1 && python3 -m pip --version >/dev/null 2>&1; then
    if run_update_cmd python3 -m pip install --upgrade --user "$package"; then
      mark_updated "$package"
    else
      mark_failed "$package"
    fi
    return 0
  fi

  mark_skipped "$package"
}

update_brew() {
  printf 'vibe-cli-kit update\n'
  printf 'package-manager=brew dry-run=%s sync=%s\n\n' "$UPDATE_DRY_RUN" "$UPDATE_SYNC"

  if run_update_cmd brew update; then
    if [ "$UPDATE_DRY_RUN" -eq 1 ]; then
      printf 'plan  refresh brew metadata\n'
    else
      printf 'ok    refreshed brew metadata\n'
    fi
  else
    mark_failed "brew metadata"
  fi

  if [ "$(detect_platform)" = "macos" ]; then
    brew_update_cask ghostty
  else
    mark_skipped "ghostty"
  fi

  brew_update_formula yazi
  brew_update_formula lsd
  brew_update_formula bat
  brew_update_formula tmux
  brew_update_formula fzf
  brew_update_formula fd
  brew_update_formula atuin
  brew_update_formula zoxide
  brew_update_formula neovim
  brew_update_formula ripgrep
  brew_update_formula lazygit
  brew_update_formula rich-cli
  brew_update_formula glow
  brew_update_formula fastfetch
  brew_update_formula btop
}

update_apt() {
  printf 'vibe-cli-kit update\n'
  printf 'package-manager=apt dry-run=%s sync=%s\n\n' "$UPDATE_DRY_RUN" "$UPDATE_SYNC"

  if run_update_root_cmd apt-get update; then
    if [ "$UPDATE_DRY_RUN" -eq 1 ]; then
      printf 'plan  refresh apt metadata\n'
    else
      printf 'ok    refreshed apt metadata\n'
    fi
  else
    mark_failed "apt metadata"
  fi

  mark_skipped "ghostty"
  apt_update_package yazi
  apt_update_package lsd
  apt_update_package bat
  apt_update_package fd-find
  apt_update_package tmux
  apt_update_package fzf
  apt_update_package atuin
  apt_update_package zoxide
  apt_update_package neovim
  apt_update_package ripgrep
  apt_update_package lazygit
  apt_update_package glow
  apt_update_package fastfetch
  apt_update_package btop
  update_python_cli rich-cli
}

parse_update_args() {
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --dry-run)
        UPDATE_DRY_RUN=1
        ;;
      --no-sync)
        UPDATE_SYNC=0
        ;;
      *)
        usage >&2
        exit 1
        ;;
    esac
    shift
  done
}

update_tools() {
  parse_update_args "$@"
  reset_update_state
  manager="$(detect_package_manager)"

  case "$manager" in
    brew) update_brew ;;
    apt) update_apt ;;
    *)
      printf 'fail  unsupported package manager\n' >&2
      exit 1
      ;;
  esac

  if [ "$UPDATE_SYNC" -eq 1 ]; then
    printf '\n'
    old_sync_dry_run="$SYNC_DRY_RUN"
    old_sync_target="$SYNC_TARGET"
    old_sync_mode="$SYNC_MODE"
    SYNC_DRY_RUN="$UPDATE_DRY_RUN"
    SYNC_TARGET=all
    SYNC_MODE=overwrite
    sync_configs
    SYNC_DRY_RUN="$old_sync_dry_run"
    SYNC_TARGET="$old_sync_target"
    SYNC_MODE="$old_sync_mode"
  fi

  print_update_block "Updated" "$UPDATED_ITEMS"
  print_update_block "Skipped" "$SKIPPED_ITEMS"
  print_update_block "Failed" "$FAILED_ITEMS"
}

editor_command() {
  if command -v nvim >/dev/null 2>&1; then
    printf 'nvim .\n'
  else
    printf '%s\n' "${SHELL:-/bin/sh}"
  fi
}

command_exists() {
  command -v "$1" >/dev/null 2>&1
}

load_session_config() {
  if [ "$SESSION_CONFIG_LOADED" -eq 1 ]; then
    return 0
  fi

  if [ -f "$SESSION_CONFIG_FILE" ]; then
    # User-owned overrides for session pane commands and ratios.
    # shellcheck disable=SC1090
    . "$SESSION_CONFIG_FILE"
  fi

  SESSION_CONFIG_LOADED=1
}

session_config_value() {
  var_name="$1"
  default_value="$2"
  load_session_config
  eval "value=\${$var_name-}"
  if [ -n "${value:-}" ]; then
    printf '%s\n' "$value"
  else
    printf '%s\n' "$default_value"
  fi
}

resolve_session_command() {
  spec="$1"
  case "$spec" in
    ""|@none)
      printf '\n'
      ;;
    @shell)
      printf '%s\n' "${SHELL:-/bin/sh}"
      ;;
    @git)
      git_command
      ;;
    @agent)
      agent_command
      ;;
    @dev)
      project_dev_command
      ;;
    @test)
      project_test_command
      ;;
    @editor)
      editor_command
      ;;
    @yazi)
      printf 'yazi\n'
      ;;
    *)
      printf '%s\n' "$spec"
      ;;
  esac
}

detect_project_type() {
  if [ -f package.json ]; then
    if [ -f nest-cli.json ] || grep -Eq '"@nestjs/(core|cli)"[[:space:]]*:' package.json; then
      printf 'nestjs\n'
    elif [ -f next.config.js ] || [ -f next.config.mjs ] || [ -f next.config.ts ] || grep -Eq '"next"[[:space:]]*:' package.json; then
      printf 'nextjs\n'
    elif [ -f vite.config.js ] || [ -f vite.config.mjs ] || [ -f vite.config.ts ] || [ -f vite.config.cjs ] || grep -Eq '"vite"[[:space:]]*:' package.json; then
      printf 'vite\n'
    else
      printf 'node\n'
    fi
  elif [ -f manage.py ]; then
    printf 'django\n'
  elif [ -f pyproject.toml ] || [ -f requirements.txt ] || [ -f requirements-dev.txt ]; then
    if grep -Eqi 'fastapi|uvicorn' pyproject.toml requirements.txt requirements-dev.txt 2>/dev/null; then
      printf 'fastapi\n'
    else
      printf 'python\n'
    fi
  elif [ -f Cargo.toml ]; then
    if grep -Eq '^\[workspace\]' Cargo.toml; then
      printf 'rust-workspace\n'
    else
      printf 'rust\n'
    fi
  elif [ -f go.work ]; then
    printf 'go-workspace\n'
  elif [ -f go.mod ]; then
    printf 'go\n'
  elif [ -f docker-compose.yml ] || [ -f compose.yml ] || [ -f compose.yaml ] || [ -f docker-compose.yaml ]; then
    printf 'docker-compose\n'
  else
    printf 'generic\n'
  fi
}

detect_node_runner() {
  if [ -f pnpm-lock.yaml ] && command_exists pnpm; then
    printf 'pnpm\n'
  elif [ -f yarn.lock ] && command_exists yarn; then
    printf 'yarn\n'
  elif [ -f package-lock.json ] && command_exists npm; then
    printf 'npm\n'
  elif command_exists pnpm; then
    printf 'pnpm\n'
  elif command_exists npm; then
    printf 'npm\n'
  elif command_exists yarn; then
    printf 'yarn\n'
  else
    printf 'node\n'
  fi
}

package_has_script() {
  script_name="$1"
  package_scripts | grep -Fxq "$script_name"
}

package_scripts() {
  [ -f package.json ] || return 1

  if command_exists python3; then
    python3 - <<'PY' 2>/dev/null || return 1
import json

with open("package.json", "r", encoding="utf-8") as f:
    data = json.load(f)

scripts = data.get("scripts", {})
if isinstance(scripts, dict):
    for name in scripts:
        print(name)
PY
    return 0
  fi

  if command_exists python; then
    python - <<'PY' 2>/dev/null || return 1
import json

with open("package.json", "r", encoding="utf-8") as f:
    data = json.load(f)

scripts = data.get("scripts", {})
if isinstance(scripts, dict):
    for name in scripts:
        print(name)
PY
    return 0
  fi

  if command_exists node; then
    node -e 'const fs=require("fs"); const data=JSON.parse(fs.readFileSync("package.json","utf8")); const scripts=data && data.scripts; if (scripts && typeof scripts==="object" && !Array.isArray(scripts)) { for (const name of Object.keys(scripts)) console.log(name); }' 2>/dev/null || return 1
    return 0
  fi

  awk '
    BEGIN {
      in_scripts = 0
      depth = 0
    }
    {
      line = $0
      if (!in_scripts) {
        if (line ~ /"scripts"[[:space:]]*:[[:space:]]*{/) {
          in_scripts = 1
          depth = 1
        }
        next
      }

      if (match(line, /^[[:space:]]*"([^"]+)"[[:space:]]*:/, parts)) {
        print parts[1]
      }

      opens = gsub(/{/, "{", line)
      closes = gsub(/}/, "}", line)
      depth += opens - closes
      if (depth <= 0) {
        exit
      }
    }
  ' package.json
}

package_first_script_matching() {
  pattern="$1"
  package_scripts | grep -E "$pattern" | head -n 1
}

package_scripts_inline() {
  scripts="$(package_scripts 2>/dev/null || true)"
  [ -n "$scripts" ] || return 0

  OLD_IFS=$IFS
  IFS='
'
  output=
  for script_name in $scripts; do
    [ -n "$script_name" ] || continue
    if [ -z "$output" ]; then
      output="$script_name"
    else
      output="$output, $script_name"
    fi
  done
  IFS=$OLD_IFS
  printf '%s\n' "$output"
}

package_best_test_script() {
  package_scripts | while IFS= read -r script_name; do
    case "$script_name" in
      test) score=0 ;;
      *unit*) score=10 ;;
      *core*) score=20 ;;
      *integration*) score=30 ;;
      *runtime*) score=40 ;;
      *contract*) score=50 ;;
      *smoke*) score=60 ;;
      *all*) score=70 ;;
      *e2e*|*page*) score=90 ;;
      test:*) score=80 ;;
      *) continue ;;
    esac
    printf '%03d:%03d:%s\n' "$score" "$(printf '%s' "$script_name" | wc -c | tr -d ' ')" "$script_name"
  done | sort | head -n 1 | cut -d: -f3-
}

node_script_command() {
  script_name="$1"
  runner="$(detect_node_runner)"
  case "$runner" in
    pnpm|yarn)
      printf '%s %s\n' "$runner" "$script_name"
      ;;
    npm)
      printf 'npm run %s\n' "$script_name"
      ;;
    *)
      printf '\n'
      ;;
  esac
}

project_dev_command() {
  project_type="$(detect_project_type)"
  case "$project_type" in
    nextjs|vite|nestjs|node)
      if package_has_script dev; then
        node_script_command dev
      elif package_has_script start:dev; then
        node_script_command start:dev
      elif package_has_script start; then
        node_script_command start
      else
        printf '\n'
      fi
      ;;
    django)
      if command_exists uv; then
        printf 'uv run python manage.py runserver\n'
      else
        printf 'python3 manage.py runserver\n'
      fi
      ;;
    fastapi)
      if [ -f main.py ]; then
        if command_exists uv; then
          printf 'uv run uvicorn main:app --reload\n'
        else
          printf 'uvicorn main:app --reload\n'
        fi
      elif [ -f app/main.py ]; then
        if command_exists uv; then
          printf 'uv run uvicorn app.main:app --reload\n'
        else
          printf 'uvicorn app.main:app --reload\n'
        fi
      else
        printf '\n'
      fi
      ;;
    python)
      if [ -f app.py ]; then
        if command_exists uv; then
          printf 'uv run python app.py\n'
        else
          printf 'python3 app.py\n'
        fi
      else
        printf '\n'
      fi
      ;;
    rust|rust-workspace)
      printf 'cargo run\n'
      ;;
    go|go-workspace)
      printf 'go run .\n'
      ;;
    docker-compose)
      printf 'docker compose up\n'
      ;;
    *)
      printf '\n'
      ;;
  esac
}

project_test_command() {
  project_type="$(detect_project_type)"
  case "$project_type" in
    nextjs|vite|nestjs|node)
      if package_has_script test; then
        node_script_command test
      else
        fallback_test_script="$(package_best_test_script || true)"
        if [ -n "$fallback_test_script" ]; then
          node_script_command "$fallback_test_script"
        else
          printf '\n'
        fi
      fi
      ;;
    django|fastapi|python)
      if command_exists uv; then
        printf 'uv run pytest\n'
      elif command_exists pytest; then
        printf 'pytest\n'
      else
        printf '\n'
      fi
      ;;
    rust|rust-workspace)
      printf 'cargo test\n'
      ;;
    go|go-workspace)
      printf 'go test ./...\n'
      ;;
    *)
      printf '\n'
      ;;
  esac
}

current_project_name() {
  if command -v git >/dev/null 2>&1; then
    top_level="$(git rev-parse --show-toplevel 2>/dev/null || true)"
    if [ -n "$top_level" ]; then
      basename "$top_level"
      return 0
    fi
  fi

  basename "$PWD"
}

project_runner_label() {
  project_type="$(detect_project_type)"
  case "$project_type" in
    nextjs|vite|nestjs|node)
      detect_node_runner
      ;;
    django|fastapi|python)
      if command_exists uv; then
        printf 'uv\n'
      elif command_exists python3; then
        printf 'python3\n'
      else
        printf 'python\n'
      fi
      ;;
    rust|rust-workspace)
      printf 'cargo\n'
      ;;
    go|go-workspace)
      printf 'go\n'
      ;;
    docker-compose)
      printf 'docker\n'
      ;;
    *)
      printf 'generic\n'
      ;;
  esac
}

project_command() {
  if [ "$#" -gt 0 ]; then
    case "$1" in
      -h|--help|help)
        project_help
        exit 0
        ;;
      *)
        usage >&2
        exit 1
        ;;
    esac
  fi

  project_type="$(detect_project_type)"
  runner="$(project_runner_label)"
  dev_cmd="$(project_dev_command)"
  test_cmd="$(project_test_command)"
  project_name="$(current_project_name)"

  printf '%s project\n\n' "$project_name"
  printf 'type: %s\n' "$project_type"
  printf 'runner: %s\n' "$runner"
  if [ -n "$dev_cmd" ]; then
    printf 'dev: %s\n' "$dev_cmd"
  else
    printf 'dev: (no default suggestion)\n'
  fi
  if [ -n "$test_cmd" ]; then
    printf 'test: %s\n' "$test_cmd"
  else
    printf 'test: (no default suggestion)\n'
  fi
}

restart_detection_hint() {
  project_type="$(detect_project_type)"
  runner="$(project_runner_label)"
  scripts_inline="$(package_scripts_inline)"

  printf 'fail  no command provided and no default dev command detected\n' >&2
  printf 'hint  detected project type: %s\n' "$project_type" >&2
  printf 'hint  preferred runner: %s\n' "$runner" >&2

  case "$project_type" in
    nextjs|vite|nestjs|node)
      if [ -n "$scripts_inline" ]; then
        printf 'hint  package.json scripts: %s\n' "$scripts_inline" >&2
        printf 'hint  add a standard script such as "dev", "start:dev", or "start", or run:\n' >&2
      else
        printf 'hint  package.json found, but no runnable scripts were detected\n' >&2
        printf 'hint  add a standard script such as "dev", "start:dev", or "start", or run:\n' >&2
      fi
      printf 'hint    v r --port %s -- <your-start-command>\n' "$port" >&2
      ;;
    python|fastapi|django)
      printf 'hint  python project detected, but no default entrypoint matched\n' >&2
      printf 'hint  supported defaults include manage.py, main.py, and app/main.py\n' >&2
      printf 'hint  otherwise run:\n' >&2
      printf 'hint    v r --port %s -- <your-start-command>\n' "$port" >&2
      ;;
    rust|rust-workspace|go|go-workspace|docker-compose)
      printf 'hint  project type was detected, but no safe default startup command is configured here\n' >&2
      printf 'hint  run the command explicitly, for example:\n' >&2
      printf 'hint    v r --port %s -- <your-start-command>\n' "$port" >&2
      ;;
    generic)
      printf 'hint  no supported project markers were found in the current directory\n' >&2
      printf 'hint  try running from the project root, or run the command explicitly:\n' >&2
      printf 'hint    v r --port %s -- <your-start-command>\n' "$port" >&2
      ;;
    *)
      printf 'hint  run the command explicitly:\n' >&2
      printf 'hint    v r --port %s -- <your-start-command>\n' "$port" >&2
      ;;
  esac

  printf 'hint  inspect the current detection with: v project\n' >&2
}

is_valid_port() {
  case "$1" in
    ''|*[!0-9]*)
      return 1
      ;;
    *)
      [ "$1" -ge 1 ] && [ "$1" -le 65535 ]
      ;;
  esac
}

port_listening_pids() {
  port="$1"

  if command_exists lsof; then
    lsof -tiTCP:"$port" -sTCP:LISTEN 2>/dev/null | awk '!seen[$0]++'
    return 0
  fi

  if command_exists fuser; then
    fuser -n tcp "$port" 2>/dev/null | tr ' ' '\n' | awk 'NF && !seen[$0]++ { print }'
    return 0
  fi

  printf 'fail  need lsof or fuser to inspect port %s\n' "$port" >&2
  exit 1
}

pid_list_is_alive() {
  for pid in "$@"; do
    if kill -0 "$pid" 2>/dev/null; then
      return 0
    fi
  done
  return 1
}

kill_port_processes() {
  port="$1"
  wait_seconds="$2"
  pid_lines="$(port_listening_pids "$port")"

  if [ -z "$pid_lines" ]; then
    printf 'ok    port %s already free\n' "$port"
    return 0
  fi

  OLD_IFS=$IFS
  IFS='
'
  set -- $pid_lines
  IFS=$OLD_IFS

  printf 'ok    stop port %s: %s\n' "$port" "$*"

  for pid in "$@"; do
    kill "$pid" 2>/dev/null || true
  done

  remaining="$wait_seconds"
  while [ "$remaining" -gt 0 ]; do
    if ! pid_list_is_alive "$@"; then
      printf 'ok    port %s released\n' "$port"
      return 0
    fi
    sleep 1
    remaining=$((remaining - 1))
  done

  if pid_list_is_alive "$@"; then
    printf 'warn  force kill port %s: %s\n' "$port" "$*"
    for pid in "$@"; do
      kill -9 "$pid" 2>/dev/null || true
    done
  fi

  if pid_list_is_alive "$@"; then
    printf 'fail  port %s still busy after kill: %s\n' "$port" "$*" >&2
    exit 1
  fi

  printf 'ok    port %s released\n' "$port"
}

restart_command() {
  port="${PORT:-}"
  wait_seconds=3
  port_from_positional=0

  while [ "$#" -gt 0 ]; do
    case "$1" in
      -h|--help|help)
        restart_help
        exit 0
        ;;
      --port)
        shift
        [ "$#" -gt 0 ] || {
          restart_help >&2
          exit 1
        }
        port="$1"
        ;;
      --wait)
        shift
        [ "$#" -gt 0 ] || {
          restart_help >&2
          exit 1
        }
        wait_seconds="$1"
        ;;
      --)
        shift
        break
        ;;
      [0-9]*)
        if [ "$port_from_positional" -eq 0 ] && [ -z "${port:-}" ]; then
          port="$1"
          port_from_positional=1
          shift
          break
        fi
        restart_help >&2
        exit 1
        ;;
      *)
        if [ -n "${port:-}" ]; then
          break
        fi
        restart_help >&2
        exit 1
        ;;
    esac
    shift
  done

  is_valid_port "$port" || {
    printf 'fail  invalid or missing port: %s\n' "${port:-<empty>}" >&2
    exit 1
  }

  case "$wait_seconds" in
    ''|*[!0-9]*)
      printf 'fail  invalid wait seconds: %s\n' "$wait_seconds" >&2
      exit 1
      ;;
  esac

  if [ "${1:-}" = "--" ]; then
    shift
  fi

  kill_port_processes "$port" "$wait_seconds"

  if [ "$#" -gt 0 ]; then
    printf 'ok    start command: %s\n' "$*"
    exec "$@"
  fi

  dev_cmd="$(project_dev_command)"
  if [ -z "$dev_cmd" ]; then
    restart_detection_hint
    exit 1
  fi

  printf 'ok    start command: %s\n' "$dev_cmd"
  exec sh -lc "$dev_cmd"
}

git_command() {
  if command -v lazygit >/dev/null 2>&1; then
    printf 'lazygit\n'
  else
    printf '%s\n' "${SHELL:-/bin/sh}"
  fi
}

agent_command() {
  if command -v codex >/dev/null 2>&1; then
    printf 'codex\n'
  elif command -v claude >/dev/null 2>&1; then
    printf 'claude\n'
  elif command -v aider >/dev/null 2>&1; then
    printf 'aider\n'
  else
    printf '%s\n' "${SHELL:-/bin/sh}"
  fi
}

sanitize_session_name() {
  value="$1"
  value=$(printf '%s' "$value" | tr '/ :@.' '-' | tr -cd '[:alnum:]_-')
  [ -n "$value" ] || value="main"
  printf '%s\n' "$value"
}

default_session_name() {
  layout="$1"
  base="${PWD##*/}"
  [ -n "$base" ] || base="main"
  case "$layout" in
    code) sanitize_session_name "$base" ;;
    *) sanitize_session_name "$base-$layout" ;;
  esac
}

tmux_attach_session() {
  session_name="$1"
  if [ -n "${TMUX:-}" ]; then
    exec tmux switch-client -t "$session_name"
  else
    exec tmux attach-session -t "$session_name"
  fi
}

tmux_send_if_command() {
  pane_target="$1"
  command_text="$2"
  [ -n "$command_text" ] || return 0
  tmux send-keys -t "$pane_target" "$command_text" C-m
}

tmux_new_named_session() {
  session_name="$1"
  window_name="$2"
  tmux new-session -d -s "$session_name" -c "$PWD" -n "$window_name"
}

create_main_vertical_session() {
  session_name="$1"
  window_name="$2"
  left_title="$3"
  right_top_title="$4"
  right_bottom_title="$5"
  right_width="$6"
  left_cmd="$7"
  right_top_cmd="$8"
  right_bottom_cmd="$9"

  tmux_new_named_session "$session_name" "$window_name"
  left_pane="$(tmux display-message -p -t "$session_name:1.1" '#{pane_id}')"
  right_top_pane="$(tmux split-window -h -p "$right_width" -t "$left_pane" -c "$PWD" -P -F '#{pane_id}')"
  right_bottom_pane="$(tmux split-window -v -p 50 -t "$right_top_pane" -c "$PWD" -P -F '#{pane_id}')"
  tmux select-pane -t "$left_pane" -T "$left_title"
  tmux select-pane -t "$right_top_pane" -T "$right_top_title"
  tmux select-pane -t "$right_bottom_pane" -T "$right_bottom_title"
  tmux_send_if_command "$left_pane" "$left_cmd"
  tmux_send_if_command "$right_top_pane" "$right_top_cmd"
  tmux_send_if_command "$right_bottom_pane" "$right_bottom_cmd"
}

create_quad_session() {
  session_name="$1"
  window_name="$2"
  top_left_title="$3"
  top_right_title="$4"
  bottom_left_title="$5"
  bottom_right_title="$6"
  right_width="$7"
  top_left_cmd="$8"
  top_right_cmd="$9"
  bottom_left_cmd="${10}"
  bottom_right_cmd="${11}"

  tmux_new_named_session "$session_name" "$window_name"
  top_left_pane="$(tmux display-message -p -t "$session_name:1.1" '#{pane_id}')"
  top_right_pane="$(tmux split-window -h -p "$right_width" -t "$top_left_pane" -c "$PWD" -P -F '#{pane_id}')"
  bottom_left_pane="$(tmux split-window -v -p 50 -t "$top_left_pane" -c "$PWD" -P -F '#{pane_id}')"
  bottom_right_pane="$(tmux split-window -v -p 50 -t "$top_right_pane" -c "$PWD" -P -F '#{pane_id}')"
  tmux select-pane -t "$top_left_pane" -T "$top_left_title"
  tmux select-pane -t "$top_right_pane" -T "$top_right_title"
  tmux select-pane -t "$bottom_left_pane" -T "$bottom_left_title"
  tmux select-pane -t "$bottom_right_pane" -T "$bottom_right_title"
  tmux_send_if_command "$top_left_pane" "$top_left_cmd"
  tmux_send_if_command "$top_right_pane" "$top_right_cmd"
  tmux_send_if_command "$bottom_left_pane" "$bottom_left_cmd"
  tmux_send_if_command "$bottom_right_pane" "$bottom_right_cmd"
}

create_code_session() {
  session_name="$1"
  create_main_vertical_session \
    "$session_name" \
    code \
    browser \
    shell \
    git \
    "$(session_config_value VIBE_SESSION_CODE_RIGHT_WIDTH 32)" \
    "$(resolve_session_command "$(session_config_value VIBE_SESSION_CODE_LEFT_CMD @yazi)")" \
    "$(resolve_session_command "$(session_config_value VIBE_SESSION_CODE_RIGHT_TOP_CMD @shell)")" \
    "$(resolve_session_command "$(session_config_value VIBE_SESSION_CODE_RIGHT_BOTTOM_CMD @git)")"
}

create_backend_session() {
  session_name="$1"
  create_main_vertical_session \
    "$session_name" \
    backend \
    server \
    tests \
    git \
    "$(session_config_value VIBE_SESSION_BACKEND_RIGHT_WIDTH 35)" \
    "$(resolve_session_command "$(session_config_value VIBE_SESSION_BACKEND_LEFT_CMD @dev)")" \
    "$(resolve_session_command "$(session_config_value VIBE_SESSION_BACKEND_RIGHT_TOP_CMD @test)")" \
    "$(resolve_session_command "$(session_config_value VIBE_SESSION_BACKEND_RIGHT_BOTTOM_CMD @git)")"
}

create_frontend_session() {
  session_name="$1"
  create_main_vertical_session \
    "$session_name" \
    frontend \
    browser \
    dev \
    git \
    "$(session_config_value VIBE_SESSION_FRONTEND_RIGHT_WIDTH 35)" \
    "$(resolve_session_command "$(session_config_value VIBE_SESSION_FRONTEND_LEFT_CMD @yazi)")" \
    "$(resolve_session_command "$(session_config_value VIBE_SESSION_FRONTEND_RIGHT_TOP_CMD @dev)")" \
    "$(resolve_session_command "$(session_config_value VIBE_SESSION_FRONTEND_RIGHT_BOTTOM_CMD @git)")"
}

create_ai_session() {
  session_name="$1"
  create_quad_session \
    "$session_name" \
    ai \
    yazi \
    git \
    ai \
    shell \
    "$(session_config_value VIBE_SESSION_AI_RIGHT_WIDTH 40)" \
    "$(resolve_session_command "$(session_config_value VIBE_SESSION_AI_TOP_LEFT_CMD @yazi)")" \
    "$(resolve_session_command "$(session_config_value VIBE_SESSION_AI_TOP_RIGHT_CMD @git)")" \
    "$(resolve_session_command "$(session_config_value VIBE_SESSION_AI_BOTTOM_LEFT_CMD @agent)")" \
    "$(resolve_session_command "$(session_config_value VIBE_SESSION_AI_BOTTOM_RIGHT_CMD @shell)")"
}

session_usage_error() {
  usage >&2
  exit 1
}

create_session_layout() {
  layout="$1"
  session_name="$2"
  case "$layout" in
    code) create_code_session "$session_name" ;;
    backend) create_backend_session "$session_name" ;;
    frontend) create_frontend_session "$session_name" ;;
    ai) create_ai_session "$session_name" ;;
    *) session_usage_error ;;
  esac
}

session_command() {
  [ -n "${TMUX:-}" ] || command -v tmux >/dev/null 2>&1 || {
    printf 'fail  tmux not found\n' >&2
    exit 1
  }

  layout="code"
  session_name=
  SESSION_RESET=0

  while [ "$#" -gt 0 ]; do
    case "$1" in
      -h|--help|help)
        session_help
        exit 0
        ;;
      code|backend|frontend|ai)
        layout="$1"
        ;;
      --name)
        shift
        [ "$#" -gt 0 ] || session_usage_error
        session_name="$1"
        ;;
      --reset)
        SESSION_RESET=1
        ;;
      *)
        session_usage_error
        ;;
    esac
    shift
  done

  if [ -z "$session_name" ]; then
    session_name="$(default_session_name "$layout")"
  else
    session_name="$(sanitize_session_name "$session_name")"
  fi

  if tmux has-session -t "$session_name" 2>/dev/null; then
    if [ "$SESSION_RESET" -eq 1 ]; then
      printf 'ok    reset session %s\n' "$session_name"
      tmux kill-session -t "$session_name"
    else
      printf 'ok    reuse session %s\n' "$session_name"
      tmux_attach_session "$session_name"
    fi
  fi

  printf 'ok    create %s session %s\n' "$layout" "$session_name"
  create_session_layout "$layout" "$session_name"
  tmux_attach_session "$session_name"
}

doctor() {
  printf 'vibe-cli-kit doctor\n\n'

  check_template_store
  check_file "tmux config" "$HOME/.tmux.conf"
  check_file "session config" "$KIT_DIR/session.conf"
  check_file "session config example" "$KIT_DIR/session.conf.example"
  check_file "ghostty config" "$CONFIG_DIR/ghostty/config"
  check_file "yazi config" "$CONFIG_DIR/yazi/yazi.toml"
  check_file "yazi package" "$CONFIG_DIR/yazi/package.toml"
  check_file "cheatsheet (en)" "$CHEATSHEET_DIR/terminal-cheatsheet.en.md"
  check_file "cheatsheet (zh-CN)" "$CHEATSHEET_DIR/terminal-cheatsheet.zh-CN.md"
  check_file "cheatsheet (ja)" "$CHEATSHEET_DIR/terminal-cheatsheet.ja.md"
  check_file "script: terminal-cheatsheet" "$LOCAL_BIN_DIR/terminal-cheatsheet"
  check_file "script: tmx" "$LOCAL_BIN_DIR/tmx"
  check_file "script: v" "$LOCAL_BIN_DIR/v"
  check_file "script: e" "$LOCAL_BIN_DIR/e"
  check_file "script: fif" "$LOCAL_BIN_DIR/fif"
  check_zshrc_markers

  printf '\n'

  check_ghostty
  check_cmd "yazi" "yazi"
  check_cmd "lsd" "lsd"
  check_cmd "bat" "bat" "batcat"
  check_cmd "tmux" "tmux"
  check_cmd "fzf" "fzf"
  check_cmd "fd" "fd" "fdfind"
  check_cmd "atuin" "atuin"
  check_cmd "zoxide" "zoxide"
  check_cmd "nvim" "nvim" "neovim"
  check_cmd "ripgrep" "rg" "ripgrep"
  check_cmd "lazygit" "lazygit"
  check_cmd "rich-cli" "rich" "rich-cli"
  check_cmd "glow" "glow"
  check_cmd "fastfetch" "fastfetch"
  check_cmd "btop" "btop"
  check_yazi_plugin

  printf '\nSummary: ok=%s warn=%s fail=%s\n' "$OK_COUNT" "$WARN_COUNT" "$FAIL_COUNT"

  if [ "$FAIL_COUNT" -gt 0 ]; then
    exit 1
  fi
}

if [ "$#" -eq 0 ]; then
  open_cheatsheet
fi

case "${1:-}" in
  --lang)
    open_cheatsheet "$@"
    ;;
  doctor)
    shift
    [ "$#" -eq 0 ] || {
      usage >&2
      exit 1
    }
    doctor
    ;;
sync)
    shift
    sync_configs "$@"
    ;;
  diff)
    shift
    diff_configs "$@"
    ;;
  update)
    shift
    update_tools "$@"
    ;;
  project)
    shift
    project_command "$@"
    ;;
  r|restart)
    shift
    restart_command "$@"
    ;;
  backup)
    shift
    backup_configs "$@"
    ;;
  session)
    shift
    session_command "$@"
    ;;
  -h|--help|help)
    usage
    ;;
  *)
    usage >&2
    exit 1
    ;;
esac
