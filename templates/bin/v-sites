FILTERED_COUNT = 0
WARNINGS = []

TITLE_RE = re.compile(r"<title[^>]*>(.*?)</title>", re.IGNORECASE | re.DOTALL)
META_RE = re.compile(r"<meta\b[^>]*>", re.IGNORECASE | re.DOTALL)
ATTR_RE = re.compile(r"""([:\w-]+)\s*=\s*("[^"]*"|'[^']*'|[^\s"'=<>`]+)""", re.IGNORECASE)
SPACE_RE = re.compile(r"\s+")


def warn(message):
    WARNINGS.append(message)
    print(f"warn  {message}", file=sys.stderr)


def safari_permission_hint(path):
    warn(f"Safari data is not readable: {path}")
    print("hint  macOS requires Full Disk Access for the terminal app running this command.", file=sys.stderr)
    print("hint  Open System Settings -> Privacy & Security -> Full Disk Access.", file=sys.stderr)
    print("hint  Enable Terminal / iTerm / Ghostty, restart the terminal, then rerun:", file=sys.stderr)
    print("hint    v sites --rebuild", file=sys.stderr)


def normalize_url(url):
    parts = urlsplit(url or "")
    if parts.scheme not in {"http", "https"} or not parts.netloc:
        return ""
    host = parts.netloc.lower()
    if host.startswith("www."):
        host = host[4:]
    query_pairs = [(key, value) for key, value in parse_qsl(parts.query, keep_blank_values=True) if key.lower() not in TRACKING_PARAMS]
    query = ""
    if len(query_pairs) <= 2 and not any(key.lower() in {"token", "code", "password", "secret"} for key, _ in query_pairs):
        query = "&".join(f"{key}={value}" for key, value in query_pairs)
    path = parts.path.rstrip("/") or "/"
    return urlunsplit((parts.scheme.lower(), host, path, query, ""))


def host_of(url):
    host = urlsplit(url).netloc.lower()
    return host[4:] if host.startswith("www.") else host


def is_local_url(url):
    return host_of(url).split(":")[0] in {"localhost", "127.0.0.1", "0.0.0.0", "[::1]"}


def should_skip(url, title):
    global FILTERED_COUNT
    parts = urlsplit(url)
    joined = f"{host_of(url)}{parts.path}".lower()
    title_lower = (title or "").lower()
    query_keys = {key.lower() for key, _ in parse_qsl(parts.query, keep_blank_values=True)}
    if not title.strip() or title_lower in {"new tab", "about:blank"}:
        FILTERED_COUNT += 1
        return True
    if any(piece in joined for piece in BLOCKED_TEXT):
        FILTERED_COUNT += 1
        return True
    if any(piece in joined for piece in ADULT_TEXT) or any(piece in title_lower for piece in ADULT_TEXT):
        FILTERED_COUNT += 1
        return True
    if any(piece in url.lower() for piece in SENSITIVE_TEXT):
        FILTERED_COUNT += 1
        return True
    if query_keys & {"token", "access_token", "refresh_token", "secret", "password", "code"}:
        FILTERED_COUNT += 1
        return True
    if any(piece in title_lower for piece in BAD_TITLES):
        FILTERED_COUNT += 1
        return True
    return False


def cache_dirs_from_env():
    configured = os.environ.get("VIBE_SITES_CACHE_DIRS", "").strip()
    if not configured:
        return []
    return [Path(piece).expanduser() for piece in configured.split(os.pathsep) if piece.strip()]


def cache_dirs():
    seen = set()
    dirs = []
    for path in cache_dirs_from_env() or CACHE_DIRS:
        resolved = str(path)
        if resolved in seen:
            continue
        seen.add(resolved)
        if path.exists() and path.is_dir():
            dirs.append(path)
    return dirs


def cache_files(paths):
    files = []
    for root in paths:
        try:
            candidates = root.rglob("*")
            for path in candidates:
                if len(files) >= MAX_CACHE_FILES:
                    return files
                if not path.is_file():
                    continue
                try:
                    size = path.stat().st_size
                except OSError:
                    continue
                if 0 < size <= MAX_CACHE_FILE_BYTES:
                    files.append(path)
        except PermissionError:
            warn(f"cache directory is not readable: {root}")
        except OSError as exc:
            warn(f"cache directory could not be scanned: {root}: {exc}")
    return files


def decode_cache_bytes(data):
    text = data.decode("utf-8", "ignore")
    if not text.strip():
        text = data.decode("latin-1", "ignore")
    return text


def clean_cached_title(value):
    text = html.unescape(SPACE_RE.sub(" ", value or "")).strip()
    if len(text) > 90:
        text = text[:87].rstrip() + "..."
    return text


def clean_cached_description(value):
    text = html.unescape(SPACE_RE.sub(" ", value or "")).strip()
    if len(text) < 24:
        return ""
    if any(piece in text.lower() for piece in SENSITIVE_TEXT):
        return ""
    if len(text) > 180:
        text = text[:177].rstrip() + "..."
    return text


def html_attrs(tag):
    attrs = {}
    for name, value in ATTR_RE.findall(tag):
        attrs[name.lower()] = value.strip("\"'")
    return attrs


def cached_title(text):
    match = TITLE_RE.search(text)
    if not match:
        return ""
    title = clean_cached_title(match.group(1))
    if not title or any(piece in title.lower() for piece in BAD_TITLES):
        return ""
    return title


def cached_description(text):
    candidates = []
    for tag in META_RE.findall(text):
        attrs = html_attrs(tag)
        name = (attrs.get("name") or attrs.get("property") or "").lower()
        if name not in {"description", "og:description", "twitter:description"}:
            continue
        description = clean_cached_description(attrs.get("content", ""))
        if description:
            candidates.append(description)
    if not candidates:
        return ""
    return max(candidates, key=len)


def cache_category_signals(text):
    lowered = text.lower()
    matches = []
    best_category = ""
    best_count = 0
    for category, needles in CATEGORY_RULES:
        hit_needles = sorted({needle for needle in needles if needle.lower() in lowered})
        if not hit_needles:
            continue
        matches.extend(hit_needles[:3])
        if len(hit_needles) > best_count:
            best_category = category
            best_count = len(hit_needles)
    return best_category, sorted(set(matches))[:5]


def build_cache_index(items):
    roots = cache_dirs()
    if not roots:
        return {}, 0

    targets = {}
    for item in items:
        url = item.get("url", "")
        host = host_of(url)
        if not url or not host:
            continue
        parts = urlsplit(url)
        path_key = f"{host}{parts.path}".lower() if parts.path and parts.path != "/" else host
        targets.setdefault(host, {})[url] = {url.lower(), path_key}

    index = {}
    inspected = 0
    for path in cache_files(roots):
        try:
            data = path.read_bytes()
        except PermissionError:
            warn(f"cache file is not readable: {path}")
            continue
        except OSError:
            continue
        text = decode_cache_bytes(data)
        lowered = text.lower()
        if not lowered:
            continue
        inspected += 1
        for host, urls in targets.items():
            if host not in lowered:
                continue
            title = cached_title(text)
            description = cached_description(text)
            cache_category, signals = cache_category_signals(text)
            if not title and not description and not cache_category and not signals:
                continue
            for url, markers in urls.items():
                if any(marker and marker in lowered for marker in markers):
                    entry = index.setdefault(url, {"title": "", "description": "", "category": "", "signals": set()})
                    if title and len(title) > len(entry["title"]):
                        entry["title"] = title
                    if description and len(description) > len(entry["description"]):
                        entry["description"] = description
                    if cache_category:
                        entry["category"] = cache_category
                    entry["signals"].update(signals)
    return index, inspected


def title_is_generic(item):
    title = (item.get("title") or "").strip().lower()
    host = host_of(item.get("url", "")).lower()
    return not title or title in {host, "untitled", "new tab"} or len(title) < 8


def apply_cache_index(items, cache_index):
    changed = 0
    for item in items:
        entry = cache_index.get(item.get("url", ""))
        if not entry:
            continue
        if entry.get("title") and (title_is_generic(item) or len(entry["title"]) > len(item.get("title", ""))):
            item["title"] = entry["title"]
        if entry.get("category"):
            item["cache_category"] = entry["category"]
        signals = sorted(entry.get("signals", []))
        if entry.get("description"):
            item["description"] = entry["description"]
        elif signals:
            item["cache_signals"] = signals
            item["description"] = f"缓存页面命中：{'、'.join(signals[:4])}。"
        changed += 1
    return changed


def apply_favicon_index(items, favicon_index):
    by_host = {}
    for url, icon in favicon_index.items():
        by_host.setdefault(host_of(url), icon)
    for item in items:
        icon = favicon_index.get(item.get("url", "")) or by_host.get(host_of(item.get("url", "")))
        if icon:
            item["icon"] = icon


def copy_database(path, tmpdir, label):
    if not path.exists():
        return None
    target = Path(tmpdir) / f"{label}.sqlite"
    try:
        shutil.copy2(path, target)
        return target
    except PermissionError:
        if label.startswith("Safari"):
            safari_permission_hint(path)
        else:
            warn(f"{label} is not readable: {path}")
    except OSError as exc:
        warn(f"{label} could not be copied: {exc}")
    return None


def chrome_time_to_iso(value):
    if not value:
        return ""
    unix = (value / 1_000_000) - 11644473600
    try:
        return datetime.fromtimestamp(unix, tz=timezone.utc).date().isoformat()
    except (OverflowError, OSError):
        return ""


def safari_time_to_iso(value):
    if value is None:
        return ""
    try:
        date = datetime(2001, 1, 1, tzinfo=timezone.utc) + timedelta(seconds=float(value))
        return date.date().isoformat()
    except (OverflowError, OSError, ValueError):
        return ""


def read_chrome_history(browser, tmpdir, limit):
    db = copy_database(browser["history"], tmpdir, browser["name"].replace(" ", "_"))
    if not db:
        return []
    try:
        con = sqlite3.connect(db)
        con.row_factory = sqlite3.Row
        rows = con.execute(
            """
            select url, title, visit_count, typed_count, last_visit_time
            from urls
            where visit_count > 0
            order by visit_count desc, last_visit_time desc
            limit ?
            """,
            (limit,),
        ).fetchall()
        con.close()
    except sqlite3.DatabaseError as exc:
        warn(f"{browser['name']} history could not be read: {exc}")
        return []

    items = []
    for row in rows:
        url = normalize_url(row["url"])
        title = (row["title"] or host_of(url)).strip()
        if not url or should_skip(url, title):
            continue
        items.append(
            {
                "url": url,
                "title": title,
                "visit_count": int(row["visit_count"] or 0),
                "typed_count": int(row["typed_count"] or 0),
                "last_visit": chrome_time_to_iso(row["last_visit_time"]),
                "sources": [browser["name"]],
                "bookmarked": False,
            }
        )
    return items


def read_safari_history(tmpdir, limit):
    db = copy_database(SAFARI["history"], tmpdir, "Safari_History")
    if not db:
        return []
    try:
        con = sqlite3.connect(db)
        con.row_factory = sqlite3.Row
        rows = con.execute(
            """
            select hi.url, hi.visit_count, hv.title, max(hv.visit_time) as last_visit_time
            from history_items hi
            left join history_visits hv on hv.history_item = hi.id
            where hi.visit_count > 0
            group by hi.id
            order by hi.visit_count desc, last_visit_time desc
            limit ?
            """,
            (limit,),
        ).fetchall()
        con.close()
    except sqlite3.DatabaseError as exc:
        warn(f"Safari history could not be read: {exc}")
        return []

    items = []
    for row in rows:
        url = normalize_url(row["url"])
        title = (row["title"] or host_of(url)).strip()
        if not url or should_skip(url, title):
            continue
        items.append(
            {
                "url": url,
                "title": title,
                "visit_count": int(row["visit_count"] or 0),
                "typed_count": 0,
                "last_visit": safari_time_to_iso(row["last_visit_time"]),
                "sources": [SAFARI["name"]],
                "bookmarked": False,
            }
        )
    return items


def walk_chrome_bookmark_node(node, browser_name, folder="", out=None):
    out = out if out is not None else []
    if node.get("type") == "url":
        url = normalize_url(node.get("url", ""))
        title = (node.get("name") or "").strip()
        if url and not should_skip(url, title):
            out.append(
                {
                    "url": url,
                    "title": title or host_of(url),
                    "visit_count": 0,
                    "typed_count": 0,
                    "last_visit": "",
                    "sources": [browser_name],
                    "bookmark_folder": folder,
                    "bookmarked": True,
                }
            )
    for child in node.get("children", []) or []:
        next_folder = folder
        if child.get("type") == "folder" and child.get("name"):
            next_folder = f"{folder} / {child['name']}".strip(" /")
        walk_chrome_bookmark_node(child, browser_name, next_folder, out)
    return out


def read_chrome_bookmarks(browser):
    path = browser["bookmarks"]
    if not path.exists():
        return []
    try:
        with path.open() as fh:
            data = json.load(fh)
    except (OSError, json.JSONDecodeError) as exc:
        warn(f"{browser['name']} bookmarks could not be read: {exc}")
        return []

    items = []
    for root in (data.get("roots") or {}).values():
        if isinstance(root, dict):
            walk_chrome_bookmark_node(root, browser["name"], "", items)
    return items


def image_data_uri(data):
    if not data:
        return ""
    return "data:image/png;base64," + base64.b64encode(data).decode("ascii")


def read_chrome_favicons(browser, tmpdir):
    db = copy_database(browser.get("favicons", Path()), tmpdir, f"{browser['name'].replace(' ', '_')}_Favicons")
    if not db:
        return {}
    try:
        con = sqlite3.connect(f"file:{db}?immutable=1", uri=True)
        con.row_factory = sqlite3.Row
        rows = con.execute(
            """
            select icon_mapping.page_url, favicon_bitmaps.image_data, favicon_bitmaps.width, favicon_bitmaps.height
            from icon_mapping
            join favicon_bitmaps on favicon_bitmaps.icon_id = icon_mapping.icon_id
            where favicon_bitmaps.image_data is not null
            order by icon_mapping.page_url, favicon_bitmaps.width desc, favicon_bitmaps.height desc
            """
        ).fetchall()
        con.close()
    except sqlite3.DatabaseError as exc:
        warn(f"{browser['name']} favicons could not be read: {exc}")
        return {}

    icons = {}
    for row in rows:
        url = normalize_url(row["page_url"])
        if not url or url in icons:
            continue
        icon = image_data_uri(row["image_data"])
        if icon:
            icons[url] = icon
    return icons


def walk_safari_bookmark_node(node, folder="", out=None):
    out = out if out is not None else []
    node_type = node.get("WebBookmarkType")
    title = (node.get("Title") or "").strip()
    if node_type == "WebBookmarkTypeLeaf":
        url = normalize_url(node.get("URLString", ""))
        uri_title = ((node.get("URIDictionary") or {}).get("title") or title or "").strip()
        if url and not should_skip(url, uri_title):
            out.append(
                {
                    "url": url,
                    "title": uri_title or host_of(url),
                    "visit_count": 0,
                    "typed_count": 0,
                    "last_visit": "",
                    "sources": [SAFARI["name"]],
                    "bookmark_folder": folder,
                    "bookmarked": True,
                }
            )
    for child in node.get("Children", []) or []:
        next_folder = folder
        child_title = (child.get("Title") or "").strip()
        if child.get("WebBookmarkType") == "WebBookmarkTypeList" and child_title:
            next_folder = f"{folder} / {child_title}".strip(" /")
        walk_safari_bookmark_node(child, next_folder, out)
    return out


def read_safari_bookmarks():
    path = SAFARI["bookmarks"]
    if not path.exists():
        return []
    try:
        with path.open("rb") as fh:
            data = plistlib.load(fh)
    except PermissionError:
        safari_permission_hint(path)
        return []
    except (OSError, plistlib.InvalidFileException) as exc:
        warn(f"Safari bookmarks could not be read: {exc}")
        return []
    return walk_safari_bookmark_node(data)


def merge_key(item):
    if is_local_url(item["url"]):
        parts = urlsplit(item["url"])
        return f"local::{parts.scheme.lower()}://{host_of(item['url'])}"
    return f"host::{host_of(item['url'])}"


def representative_rank(item):
    rank = score(item)
    if category_for(item) == "服务后台 / 账单":
        text = f"{item['url']} {item['title']}".lower()
        rank += 10_000
        for keyword, weight in SERVICE_REPRESENTATIVE_KEYWORDS:
            if keyword in text:
                rank += weight
    return rank


def item_entry(item):
    parts = urlsplit(item.get("url", ""))
    path = parts.path or "/"
    if parts.query:
        path = f"{path}?{parts.query}"
    if len(path) > 34:
        path = path[:31].rstrip() + "..."
    return {
        "title": display_name(item),
        "url": item.get("url", ""),
        "path": path,
        "visit_count": item.get("visit_count", 0),
        "last_visit": item.get("last_visit", ""),
        "_score": score(item),
    }


def ensure_entries(item):
    if "_entries" not in item:
        item["_entries"] = [item_entry(item)]
    return item["_entries"]


def merge_entries(target, source):
    entries = {entry["url"]: entry for entry in ensure_entries(target)}
    for entry in ensure_entries(source):
        current = entries.get(entry["url"])
        if not current or entry["_score"] > current.get("_score", 0):
            entries[entry["url"]] = entry
    target["_entries"] = sorted(entries.values(), key=lambda entry: entry.get("_score", 0), reverse=True)


def absorb_item(target, source, update_title=False):
    merge_entries(target, source)
    target["visit_count"] += source.get("visit_count", 0)
    target["typed_count"] += source.get("typed_count", 0)
    target["bookmarked"] = target.get("bookmarked") or source.get("bookmarked")
    if source.get("icon") and not target.get("icon"):
        target["icon"] = source["icon"]
    if source.get("bookmark_folder") and not target.get("bookmark_folder"):
        target["bookmark_folder"] = source["bookmark_folder"]
    target["sources"] = sorted(set(target["sources"]) | set(source["sources"]))
    if source.get("last_visit", "") > target.get("last_visit", ""):
        target["last_visit"] = source["last_visit"]
    if update_title and len(source["title"]) > len(target["title"]) and source.get("visit_count", 0) >= target.get("visit_count", 0):
        target["title"] = source["title"]


def merge_items(items):
    merged = {}
    for item in items:
        ensure_entries(item)
        key = merge_key(item)
        item["_representative_rank"] = representative_rank(item)
        current = merged.get(key)
        if not current:
            merged[key] = item
            continue

        if item["_representative_rank"] > current.get("_representative_rank", representative_rank(current)):
            absorb_item(item, current)
            merged[key] = item
        else:
            absorb_item(current, item, update_title=True)
    return list(merged.values())


def rule_category_for(item):
    text = f"{item['url']} {item['title']}".lower()
    for category, needles in STRONG_CATEGORY_RULES:
        if any(needle in text for needle in needles):
            return category
    for category, needles in CATEGORY_RULES:
        if any(needle in text for needle in needles):
            return category
    return "其他网站"


def category_for(item):
    category = rule_category_for(item)
    cache_category = item.get("cache_category")
    if not cache_category:
        return category
    if cache_category == "本地开发" and category != "本地开发":
        return category
    protected_categories = {"本地开发", "AI 助手", "代码 / 仓库", "社区 / 资讯", "邮箱 / 协作", "生活 / 出行", "金融 / 政务"}
    if category in protected_categories:
        return category
    return cache_category


def describe(item):
    category = item.get("category", "")
    if item.get("bookmarked") and item.get("bookmark_folder"):
        return f"书签：{item['bookmark_folder']}。"
    if category == "本地开发":
        return "本地开发服务。"
    if category == "AI 平台 / API":
        return "模型服务、API 控制台或智能体平台。"
    if category == "服务后台 / 账单":
        return "服务管理、账号数据、用量、余额或账单入口。"
    if category == "云服务 / 部署":
        return "云资源、部署、域名或观测控制台。"
    if category == "邮箱 / 协作":
        return "邮件、文档协作或团队工作流。"
    if category == "代码 / 仓库":
        return "代码仓库、开发文档或技术社区入口。"
    if item["visit_count"] >= 20:
        return "高频访问，建议保留在首页。"
    if item["last_visit"]:
        return f"最近访问于 {item['last_visit']}。"
    return "常用页面入口。"


def score(item):
    return item.get("visit_count", 0) * 3 + item.get("typed_count", 0) * 6 + (18 if item.get("bookmarked") else 0) + len(item.get("sources", [])) * 4


def display_name(item):
    title = " ".join((item["title"] or "").split())
    if len(title) > 58:
        title = title[:55].rstrip() + "..."
    return title or host_of(item["url"])


def compact_item(item):
    url = item["url"]
    links = [
        {key: entry[key] for key in ("title", "url", "path", "visit_count", "last_visit")}
        for entry in ensure_entries(item)
        if entry.get("url") and entry.get("url") != url
    ][:3]
    return {
        "title": display_name(item),
        "url": url,
        "host": host_of(url),
        "description": item.get("description") or describe(item),
        "icon": item.get("icon", ""),
        "visit_count": item.get("visit_count", 0),
        "bookmarked": item.get("bookmarked", False),
        "sources": item.get("sources", []),
        "category": item.get("category", "其他网站"),
        "last_visit": item.get("last_visit", ""),
        "links": links,
    }


def average_visit_count(group):
    items = group.get("items", [])
    if not items:
        return 0
    return sum(item.get("visit_count", 0) for item in items) / len(items)


def group_sort_key(group):
    items = group.get("items", [])
    best_item_score = max((score(item) for item in items), default=0)
    return (-average_visit_count(group), -best_item_score, -len(items), group["name"])


def build_groups(items):
    grouped = defaultdict(list)
    for item in sorted(items, key=score, reverse=True):
        item["category"] = category_for(item)
        item["description"] = item.get("description") or describe(item)
        grouped[item["category"]].append(item)

    high_frequency_items = [item for item in sorted(items, key=score, reverse=True) if item.get("category") != "本地开发"]
    groups = [
        {
            "name": "高频网站",
            "items": [compact_item(item) for item in high_frequency_items[:18]],
        }
    ]
    for category, raw_items in sorted(grouped.items(), key=lambda pair: (-len(pair[1]), pair[0])):
        limit = 24 if category in {"本地开发", "服务后台 / 账单"} else 18 if category in {"产品 / 项目后台", "AI 平台 / API", "代码 / 仓库"} else 12
        groups.append({"name": category, "items": [compact_item(item) for item in sorted(raw_items, key=score, reverse=True)[:limit]]})
    return sorted(groups, key=group_sort_key)


