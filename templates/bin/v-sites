    .card:hover {{ transform:translateY(-3px); border-color:var(--accent); }}
    .cardTop {{ display:flex; justify-content:space-between; align-items:center; gap:12px; }}
    .host {{ color:var(--accent); font-size:12px; font-weight:800; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }}
    .heat {{ color:var(--gold); font-size:12px; font-weight:800; flex:0 0 auto; }}
    .title {{ font-weight:750; line-height:1.35; overflow-wrap:anywhere; }}
    .desc {{ color:var(--muted); line-height:1.5; font-size:13px; }}
    .meta {{ display:flex; gap:7px; flex-wrap:wrap; align-self:end; }}
    .tag {{ border:1px solid var(--line); padding:4px 7px; font-size:11px; color:var(--muted); background:var(--soft); }}
    .tag.strong {{ background:rgba(23,108,95,.10); border-color:rgba(23,108,95,.24); color:var(--accent); }}
    .empty {{ display:none; border:1px dashed var(--line); background:rgba(255,255,255,.7); padding:40px; color:var(--muted); text-align:center; }}
    footer {{ margin-top:34px; color:var(--muted); font-size:12px; line-height:1.7; }}
    @media (max-width:760px) {{ header,.layout {{ grid-template-columns:1fr; }} .sidebar {{ position:static; max-height:none; }} .tabs {{ grid-template-columns:repeat(auto-fit,minmax(128px,1fr)); }} }}
  </style>
</head>
<body>
  <main class="shell">
    <header>
      <div class="hero">
        <div class="eyebrow">PRIVATE START PAGE</div>
        <h1>常用网址导航</h1>
        <p class="sub">基于 Chrome、Edge、Safari 的书签和高频历史记录生成。默认过滤登录回跳、token、敏感路径、粘贴站和成人内容；所有结果只写入本机配置目录。</p>
      </div>
      <div class="summary" id="stats"></div>
    </header>
    <div class="layout">
      <aside class="sidebar">
        <div class="sidebarTitle">FILTERS</div>
        <input id="search" type="search" placeholder="搜索标题、说明或网址">
        <nav class="tabs" id="tabs"></nav>
      </aside>
      <section id="content"></section>
    </div>
    <div class="empty" id="empty">没有匹配的网址</div>
    <footer>生成时间：{generated}。本页面是本地静态文件，不会上传浏览记录；浏览器数据库只会复制到临时目录读取，脚本结束后自动清理。</footer>
  </main>
  <script>
    const groups = {groups_json};
    const stats = {stats_json};
    const statsEl = document.querySelector('#stats');
    const content = document.querySelector('#content');
    const empty = document.querySelector('#empty');
    const search = document.querySelector('#search');
    const tabs = document.querySelector('#tabs');
    let activeCategory = '';
    const esc = value => String(value ?? '').replace(/[&<>"']/g, ch => ({{'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}}[ch]));
    const attr = value => esc(value).replace(/`/g, '&#96;');
    statsEl.innerHTML = [
      ['网址', stats.total_items],
      ['来源', stats.sources],
      ['分类', groups.length],
      ['已过滤', stats.filtered_items]
    ].map(([label, value]) => `<div class="stat"><b>${{esc(value)}}</b><span>${{esc(label)}}</span></div>`).join('');
    function renderTabs() {{
      tabs.innerHTML = [`<button class="tab ${{activeCategory ? '' : 'active'}}" data-category=""><span>全部</span><span>${{stats.total_items}}</span></button>`]
        .concat(groups.map(g => `<button class="tab ${{activeCategory === g.name ? 'active' : ''}}" data-category="${{attr(g.name)}}"><span>${{esc(g.name)}}</span><span>${{g.items.length}}</span></button>`))
        .join('');
    }}
    function render() {{
      const q = search.value.trim().toLowerCase();
      const c = activeCategory;
      let visible = 0;
      content.innerHTML = groups.filter(group => !c || group.name === c).map(group => {{
        const items = group.items.filter(item => {{
          const text = `${{item.title}} ${{item.description}} ${{item.url}} ${{item.sources.join(' ')}}`.toLowerCase();
          return !q || text.includes(q);
        }});
        if (!items.length) return '';
        visible += items.length;
        return `<section class="category"><h2>${{esc(group.name)}} <span>${{items.length}} 个</span></h2><div class="grid">${{items.map(item => `
          <a class="card" href="${{attr(item.url)}}" target="_blank" rel="noreferrer">
            <div class="cardTop"><div class="host">${{esc(item.host)}}</div><div class="heat">${{item.visit_count ? esc(item.visit_count) + ' 次' : '书签'}}</div></div>
            <div class="title">${{esc(item.title)}}</div>
            <div class="desc">${{esc(item.description)}}</div>
            <div class="meta">${{item.bookmarked ? '<span class="tag strong">书签</span>' : ''}}<span class="tag">${{esc(item.sources.join(' / '))}}</span></div>
          </a>`).join('')}}</div></section>`;
      }}).join('');
      empty.style.display = visible ? 'none' : 'block';
      renderTabs();
    }}
    search.addEventListener('input', render);
    tabs.addEventListener('click', event => {{
      const button = event.target.closest('button[data-category]');
      if (!button) return;
      activeCategory = button.dataset.category;
      render();
    }});
    render();
  </script>
</body>
</html>
"""


def build_bookmarks_html(groups):
    now = str(int(datetime.now(tz=timezone.utc).timestamp()))
    lines = [
        "<!DOCTYPE NETSCAPE-Bookmark-file-1>",
        '<META HTTP-EQUIV="Content-Type" CONTENT="text/html; charset=UTF-8">',
        "<TITLE>vibe-cli-kit 常用网址导航</TITLE>",
        "<H1>vibe-cli-kit 常用网址导航</H1>",
        "<DL><p>",
    ]
    seen = set()
    for group in groups:
        lines.append(f'  <DT><H3 ADD_DATE="{now}">{html.escape(group["name"])}</H3>')
        lines.append("  <DL><p>")
        for item in group.get("items", []):
            url = item.get("url", "")
            if not url:
                continue
            key = (group["name"], url)
            if key in seen:
                continue
            seen.add(key)
            title = html.escape(item.get("title") or item.get("host") or url)
            href = html.escape(url, quote=True)
            lines.append(f'    <DT><A HREF="{href}" ADD_DATE="{now}">{title}</A>')
        lines.append("  </DL><p>")
    lines.append("</DL><p>")
    return "\n".join(lines) + "\n"


def build(limit):
    global FILTERED_COUNT
    FILTERED_COUNT = 0
    all_items = []
    with tempfile.TemporaryDirectory(prefix="vibe-sites-") as tmpdir:
        for browser in BROWSERS:
            all_items.extend(read_chrome_history(browser, tmpdir, limit))
            all_items.extend(read_chrome_bookmarks(browser))
        all_items.extend(read_safari_history(tmpdir, limit))
        all_items.extend(read_safari_bookmarks())

    merged = sorted(merge_items(all_items), key=score, reverse=True)
    groups = build_groups(merged)
    stats = {
        "total_items": sum(len(group["items"]) for group in groups),
        "sources": len({source for group in groups for item in group["items"] for source in item["sources"]}),
        "filtered_items": FILTERED_COUNT,
        "warnings": WARNINGS,
    }
    dashboard = {"stats": stats, "groups": groups}
    SITES_DIR.mkdir(parents=True, exist_ok=True)
    DATA_FILE.write_text(json.dumps(groups, ensure_ascii=False, indent=2))
    DASHBOARD_FILE.write_text(json.dumps(dashboard, ensure_ascii=False, indent=2))
    HTML_FILE.write_text(build_html(groups, stats))
    BOOKMARKS_FILE.write_text(build_bookmarks_html(groups))
    print(f"ok    built sites: {HTML_FILE}")
    print(f"ok    bookmarks: {BOOKMARKS_FILE}")
    print(f"ok    data: {DATA_FILE}")
    if not groups:
        warn("no browser history or bookmarks were found; the page was still generated")
    return HTML_FILE


def open_file(path):
    if os.environ.get("VIBE_SITES_NO_OPEN") == "1":
        print(path)
        return 0
    if sys.platform == "darwin":
        cmd = ["open", str(path)]
    elif os.environ.get("WSL_DISTRO_NAME"):
        cmd = ["wslview", str(path)]
    else:
        cmd = ["xdg-open", str(path)]
    try:
        subprocess.Popen(cmd, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        print(f"ok    opened sites: {path}")
        return 0
    except FileNotFoundError:
        warn(f"open command not found; open this file manually: {path}")
        return 1


def parse_args(argv):
    parser = argparse.ArgumentParser(
        prog="v sites",
        description="Build and open a local browser-history start page.",
    )
    parser.add_argument("--rebuild", action="store_true", help="rebuild the sites page before opening it")
    parser.add_argument("--open", action="store_true", help="open the existing sites page without rebuilding")
    parser.add_argument("--bookmarks", action="store_true", help="print the browser-importable bookmarks HTML path")
    parser.add_argument("--no-open", action="store_true", help="build or check without opening a browser")
    parser.add_argument("--print-path", action="store_true", help="print the generated HTML path")
    parser.add_argument("--limit", type=int, default=1200, help="history rows to inspect per browser")
    return parser.parse_args(argv)


def main(argv=None):
    args = parse_args(argv or sys.argv[1:])
    if args.limit < 1:
        print("fail  --limit must be positive", file=sys.stderr)
        return 1

    needs_rebuild = args.rebuild or (args.bookmarks and not BOOKMARKS_FILE.exists()) or (not args.open and not args.bookmarks and not HTML_FILE.exists())
    if needs_rebuild:
        path = build(args.limit)
    else:
        path = HTML_FILE
        if not path.exists():
            print(f"fail  sites page does not exist: {path}", file=sys.stderr)
            print("hint  run: v sites --rebuild", file=sys.stderr)
            return 1

    if args.bookmarks:
        if not BOOKMARKS_FILE.exists():
            print(f"fail  bookmarks file does not exist: {BOOKMARKS_FILE}", file=sys.stderr)
            print("hint  run: v sites --rebuild --bookmarks", file=sys.stderr)
            return 1
        print(BOOKMARKS_FILE)
        return 0

    if args.print_path:
        print(path)
    if args.no_open:
        return 0
    return open_file(path)


if __name__ == "__main__":
    raise SystemExit(main())
