FILTERED_COUNT = 0
WARNINGS = []


def warn(message):
    WARNINGS.append(message)
    print(f"warn  {message}", file=sys.stderr)


def safari_permission_hint(path):
    warn(f"Safari data is not readable: {path}")
    print("hint  macOS requires Full Disk Access for the terminal app running this command.", file=sys.stderr)
    print("hint  Open System Settings -> Privacy & Security -> Full Disk Access.", file=sys.stderr)
    print("hint  Enable Terminal / iTerm / Ghostty, restart the terminal, then rerun:", file=sys.stderr)
    print("hint    v sites --rebuild", file=sys.stderr)


def normalize_url(url):
    parts = urlsplit(url or "")
    if parts.scheme not in {"http", "https"} or not parts.netloc:
        return ""
    host = parts.netloc.lower()
    if host.startswith("www."):
        host = host[4:]
    query_pairs = [(key, value) for key, value in parse_qsl(parts.query, keep_blank_values=True) if key.lower() not in TRACKING_PARAMS]
    query = ""
    if len(query_pairs) <= 2 and not any(key.lower() in {"token", "code", "password", "secret"} for key, _ in query_pairs):
        query = "&".join(f"{key}={value}" for key, value in query_pairs)
    path = parts.path.rstrip("/") or "/"
    return urlunsplit((parts.scheme.lower(), host, path, query, ""))


def host_of(url):
    host = urlsplit(url).netloc.lower()
    return host[4:] if host.startswith("www.") else host


def is_local_url(url):
    return host_of(url).split(":")[0] in {"localhost", "127.0.0.1", "0.0.0.0", "[::1]"}


def should_skip(url, title):
    global FILTERED_COUNT
    parts = urlsplit(url)
    joined = f"{host_of(url)}{parts.path}".lower()
    title_lower = (title or "").lower()
    query_keys = {key.lower() for key, _ in parse_qsl(parts.query, keep_blank_values=True)}
    if not title.strip() or title_lower in {"new tab", "about:blank"}:
        FILTERED_COUNT += 1
        return True
    if any(piece in joined for piece in BLOCKED_TEXT):
        FILTERED_COUNT += 1
        return True
    if any(piece in joined for piece in ADULT_TEXT) or any(piece in title_lower for piece in ADULT_TEXT):
        FILTERED_COUNT += 1
        return True
    if any(piece in url.lower() for piece in SENSITIVE_TEXT):
        FILTERED_COUNT += 1
        return True
    if query_keys & {"token", "access_token", "refresh_token", "secret", "password", "code"}:
        FILTERED_COUNT += 1
        return True
    if any(piece in title_lower for piece in BAD_TITLES):
        FILTERED_COUNT += 1
        return True
    return False


def copy_database(path, tmpdir, label):
    if not path.exists():
        return None
    target = Path(tmpdir) / f"{label}.sqlite"
    try:
        shutil.copy2(path, target)
        return target
    except PermissionError:
        if label.startswith("Safari"):
            safari_permission_hint(path)
        else:
            warn(f"{label} is not readable: {path}")
    except OSError as exc:
        warn(f"{label} could not be copied: {exc}")
    return None


def chrome_time_to_iso(value):
    if not value:
        return ""
    unix = (value / 1_000_000) - 11644473600
    try:
        return datetime.fromtimestamp(unix, tz=timezone.utc).date().isoformat()
    except (OverflowError, OSError):
        return ""


def safari_time_to_iso(value):
    if value is None:
        return ""
    try:
        date = datetime(2001, 1, 1, tzinfo=timezone.utc) + timedelta(seconds=float(value))
        return date.date().isoformat()
    except (OverflowError, OSError, ValueError):
        return ""


def read_chrome_history(browser, tmpdir, limit):
    db = copy_database(browser["history"], tmpdir, browser["name"].replace(" ", "_"))
    if not db:
        return []
    try:
        con = sqlite3.connect(db)
        con.row_factory = sqlite3.Row
        rows = con.execute(
            """
            select url, title, visit_count, typed_count, last_visit_time
            from urls
            where visit_count > 0
            order by visit_count desc, last_visit_time desc
            limit ?
            """,
            (limit,),
        ).fetchall()
        con.close()
    except sqlite3.DatabaseError as exc:
        warn(f"{browser['name']} history could not be read: {exc}")
        return []

    items = []
    for row in rows:
        url = normalize_url(row["url"])
        title = (row["title"] or host_of(url)).strip()
        if not url or should_skip(url, title):
            continue
        items.append(
            {
                "url": url,
                "title": title,
                "visit_count": int(row["visit_count"] or 0),
                "typed_count": int(row["typed_count"] or 0),
                "last_visit": chrome_time_to_iso(row["last_visit_time"]),
                "sources": [browser["name"]],
                "bookmarked": False,
            }
        )
    return items


def read_safari_history(tmpdir, limit):
    db = copy_database(SAFARI["history"], tmpdir, "Safari_History")
    if not db:
        return []
    try:
        con = sqlite3.connect(db)
        con.row_factory = sqlite3.Row
        rows = con.execute(
            """
            select hi.url, hi.visit_count, hv.title, max(hv.visit_time) as last_visit_time
            from history_items hi
            left join history_visits hv on hv.history_item = hi.id
            where hi.visit_count > 0
            group by hi.id
            order by hi.visit_count desc, last_visit_time desc
            limit ?
            """,
            (limit,),
        ).fetchall()
        con.close()
    except sqlite3.DatabaseError as exc:
        warn(f"Safari history could not be read: {exc}")
        return []

    items = []
    for row in rows:
        url = normalize_url(row["url"])
        title = (row["title"] or host_of(url)).strip()
        if not url or should_skip(url, title):
            continue
        items.append(
            {
                "url": url,
                "title": title,
                "visit_count": int(row["visit_count"] or 0),
                "typed_count": 0,
                "last_visit": safari_time_to_iso(row["last_visit_time"]),
                "sources": [SAFARI["name"]],
                "bookmarked": False,
            }
        )
    return items


def walk_chrome_bookmark_node(node, browser_name, folder="", out=None):
    out = out if out is not None else []
    if node.get("type") == "url":
        url = normalize_url(node.get("url", ""))
        title = (node.get("name") or "").strip()
        if url and not should_skip(url, title):
            out.append(
                {
                    "url": url,
                    "title": title or host_of(url),
                    "visit_count": 0,
                    "typed_count": 0,
                    "last_visit": "",
                    "sources": [browser_name],
                    "bookmark_folder": folder,
                    "bookmarked": True,
                }
            )
    for child in node.get("children", []) or []:
        next_folder = folder
        if child.get("type") == "folder" and child.get("name"):
            next_folder = f"{folder} / {child['name']}".strip(" /")
        walk_chrome_bookmark_node(child, browser_name, next_folder, out)
    return out


def read_chrome_bookmarks(browser):
    path = browser["bookmarks"]
    if not path.exists():
        return []
    try:
        with path.open() as fh:
            data = json.load(fh)
    except (OSError, json.JSONDecodeError) as exc:
        warn(f"{browser['name']} bookmarks could not be read: {exc}")
        return []

    items = []
    for root in (data.get("roots") or {}).values():
        if isinstance(root, dict):
            walk_chrome_bookmark_node(root, browser["name"], "", items)
    return items


def walk_safari_bookmark_node(node, folder="", out=None):
    out = out if out is not None else []
    node_type = node.get("WebBookmarkType")
    title = (node.get("Title") or "").strip()
    if node_type == "WebBookmarkTypeLeaf":
        url = normalize_url(node.get("URLString", ""))
        uri_title = ((node.get("URIDictionary") or {}).get("title") or title or "").strip()
        if url and not should_skip(url, uri_title):
            out.append(
                {
                    "url": url,
                    "title": uri_title or host_of(url),
                    "visit_count": 0,
                    "typed_count": 0,
                    "last_visit": "",
                    "sources": [SAFARI["name"]],
                    "bookmark_folder": folder,
                    "bookmarked": True,
                }
            )
    for child in node.get("Children", []) or []:
        next_folder = folder
        child_title = (child.get("Title") or "").strip()
        if child.get("WebBookmarkType") == "WebBookmarkTypeList" and child_title:
            next_folder = f"{folder} / {child_title}".strip(" /")
        walk_safari_bookmark_node(child, next_folder, out)
    return out


def read_safari_bookmarks():
    path = SAFARI["bookmarks"]
    if not path.exists():
        return []
    try:
        with path.open("rb") as fh:
            data = plistlib.load(fh)
    except PermissionError:
        safari_permission_hint(path)
        return []
    except (OSError, plistlib.InvalidFileException) as exc:
        warn(f"Safari bookmarks could not be read: {exc}")
        return []
    return walk_safari_bookmark_node(data)


def merge_key(item):
    if is_local_url(item["url"]):
        parts = urlsplit(item["url"])
        return f"local::{parts.scheme.lower()}://{host_of(item['url'])}"
    return f"host::{host_of(item['url'])}"


def representative_rank(item):
    rank = score(item)
    if category_for(item) == "服务后台 / 账单":
        text = f"{item['url']} {item['title']}".lower()
        rank += 10_000
        for keyword, weight in SERVICE_REPRESENTATIVE_KEYWORDS:
            if keyword in text:
                rank += weight
    return rank


def absorb_item(target, source, update_title=False):
    target["visit_count"] += source.get("visit_count", 0)
    target["typed_count"] += source.get("typed_count", 0)
    target["bookmarked"] = target.get("bookmarked") or source.get("bookmarked")
    if source.get("bookmark_folder") and not target.get("bookmark_folder"):
        target["bookmark_folder"] = source["bookmark_folder"]
    target["sources"] = sorted(set(target["sources"]) | set(source["sources"]))
    if source.get("last_visit", "") > target.get("last_visit", ""):
        target["last_visit"] = source["last_visit"]
    if update_title and len(source["title"]) > len(target["title"]) and source.get("visit_count", 0) >= target.get("visit_count", 0):
        target["title"] = source["title"]


def merge_items(items):
    merged = {}
    for item in items:
        key = merge_key(item)
        item["_representative_rank"] = representative_rank(item)
        current = merged.get(key)
        if not current:
            merged[key] = item
            continue

        if item["_representative_rank"] > current.get("_representative_rank", representative_rank(current)):
            absorb_item(item, current)
            merged[key] = item
        else:
            absorb_item(current, item, update_title=True)
    return list(merged.values())


def category_for(item):
    text = f"{item['url']} {item['title']}".lower()
    for category, needles in CATEGORY_RULES:
        if any(needle in text for needle in needles):
            return category
    return "其他网站"


def describe(item):
    category = item.get("category", "")
    if item.get("bookmarked") and item.get("bookmark_folder"):
        return f"书签：{item['bookmark_folder']}。"
    if category == "本地开发":
        return "本机开发服务，按端口和访问频率保留。"
    if category == "AI 平台 / API":
        return "模型服务、API 控制台或智能体平台。"
    if category == "服务后台 / 账单":
        return "服务管理、账号数据、用量、余额或账单入口。"
    if category == "云服务 / 部署":
        return "云资源、部署、域名或观测控制台。"
    if category == "邮箱 / 协作":
        return "邮件、文档协作或团队工作流。"
    if category == "代码 / 仓库":
        return "代码仓库、开发文档或技术社区入口。"
    if item["visit_count"] >= 20:
        return "高频访问，建议保留在首页。"
    if item["last_visit"]:
        return f"最近访问于 {item['last_visit']}。"
    return "常用页面入口。"


def score(item):
    return item["visit_count"] * 3 + item["typed_count"] * 6 + (18 if item["bookmarked"] else 0) + len(item["sources"]) * 4


def display_name(item):
    title = " ".join((item["title"] or "").split())
    if len(title) > 58:
        title = title[:55].rstrip() + "..."
    return title or host_of(item["url"])


def compact_item(item):
    return {
        "title": display_name(item),
        "url": item["url"],
        "host": host_of(item["url"]),
        "description": item.get("description") or describe(item),
        "visit_count": item.get("visit_count", 0),
        "bookmarked": item.get("bookmarked", False),
        "sources": item.get("sources", []),
        "category": item.get("category", "其他网站"),
        "last_visit": item.get("last_visit", ""),
    }


def build_groups(items):
    grouped = defaultdict(list)
    for item in sorted(items, key=score, reverse=True):
        item["category"] = category_for(item)
        item["description"] = describe(item)
        grouped[item["category"]].append(item)

    groups = [
        {
            "name": "高频网站",
            "items": [compact_item(item) for item in sorted(items, key=score, reverse=True)[:24]],
        }
    ]
    for category, raw_items in sorted(grouped.items(), key=lambda pair: (-len(pair[1]), pair[0])):
        limit = 24 if category in {"本地开发", "服务后台 / 账单"} else 18 if category in {"产品 / 项目后台", "AI 平台 / API", "代码 / 仓库"} else 12
        groups.append({"name": category, "items": [compact_item(item) for item in sorted(raw_items, key=score, reverse=True)[:limit]]})
    return groups


